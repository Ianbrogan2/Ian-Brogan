---
import type { SiteData } from '../lib/content';
interface Props { site: SiteData; }
const { site } = Astro.props;
const year = new Date().getFullYear();
---

<footer>
  <div class="container">
    <div class="footer-inner">
      <div class="footer-brand">
        <span class="footer-logo">Ian Brogan</span>
        <p class="footer-tagline">{site.footer.tagline}</p>
      </div>

      <nav aria-label="Footer navigation" class="footer-nav">
        <ul role="list">
          {site.nav_links.slice(0, 4).map(link => (
            <li><a href={link.href}>{link.label}</a></li>
          ))}
        </ul>
        <ul role="list">
          {site.nav_links.slice(4).map(link => (
            <li><a href={link.href}>{link.label}</a></li>
          ))}
        </ul>
      </nav>

      <div class="footer-contact">
        <p>
          <a href={`mailto:${site.contact.email}`}>{site.contact.email}</a>
        </p>
        <p>
          <a href={site.contact.instagram_main_url} target="_blank" rel="noopener noreferrer">
            {site.contact.instagram_main_handle}
          </a>
        </p>
        <p>
          <a href={site.contact.instagram_food_url} target="_blank" rel="noopener noreferrer">
            {site.contact.instagram_food_handle}
          </a>
        </p>
      </div>
    </div>

    <div class="footer-bottom">
      <p>&copy; {year} {site.footer.copyright_name}. All rights reserved.</p>
      <a href="/contact" class="footer-contact-link">Get in Touch</a>
    </div>
  </div>
</footer>

<style>
  footer {
    background: #050506;
    border-top: 1px solid var(--color-border);
    padding-block: clamp(3rem, 6vw, 5rem) 2rem;
  }

  .footer-inner {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 3rem;
    padding-bottom: 3rem;
    border-bottom: 1px solid var(--color-border);
  }

  .footer-logo {
    font-family: var(--font-display);
    font-size: 1.4rem;
    font-weight: 700;
    font-variation-settings: 'opsz' 36;
    letter-spacing: -0.02em;
    color: var(--color-text);
    display: block;
    margin-bottom: 0.75rem;
  }

  .footer-tagline {
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-muted);
    max-width: none;
  }

  .footer-nav {
    display: flex;
    gap: 3rem;
  }
  .footer-nav ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .footer-nav a {
    font-size: 0.85rem;
    letter-spacing: 0.04em;
    color: var(--color-muted);
    text-decoration: none;
    transition: color 0.2s;
  }
  .footer-nav a:hover { color: var(--color-text); }

  .footer-contact {
    text-align: right;
  }
  .footer-contact p { max-width: none; margin: 0; }
  .footer-contact p + p { margin-top: 0.5rem; }
  .footer-contact a {
    font-size: 0.875rem;
    color: var(--color-muted);
    text-decoration: none;
    transition: color 0.2s;
  }
  .footer-contact a:hover { color: var(--color-gold); }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 1.5rem;
    font-size: 0.775rem;
    color: rgba(237, 232, 223, 0.3);
    letter-spacing: 0.04em;
  }
  .footer-bottom p { max-width: none; margin: 0; }
  .footer-contact-link {
    color: rgba(237, 232, 223, 0.35);
    text-decoration: none;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-size: 0.7rem;
    transition: color 0.2s;
  }
  .footer-contact-link:hover { color: var(--color-gold); }

  @media (max-width: 768px) {
    .footer-inner {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    .footer-contact { text-align: left; }
    .footer-bottom { flex-direction: column; gap: 0.5rem; text-align: center; }
  }
</style>
