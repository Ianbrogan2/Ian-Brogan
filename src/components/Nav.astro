---
import type { SiteData } from '../lib/content';
interface Props { site: SiteData; }
const { site } = Astro.props;
---

<header id="site-nav" role="banner">
  <div class="ticker-strip" aria-hidden="true" role="presentation">
    <div class="tradingview-widget-container" id="tv-ticker">
      <div class="tradingview-widget-container__widget"></div>
    </div>
  </div>
  <script is:inline>
    (function() {
      var container = document.getElementById('tv-ticker');
      if (!container) return;
      var s = document.createElement('script');
      s.type = 'text/javascript';
      s.src = 'https://s3.tradingview.com/external-embedding/embed-widget-ticker-tape.js';
      s.async = true;
      s.textContent = JSON.stringify({
        symbols: [
          { proName: "AMEX:SPY",    title: "SPY" },
          { proName: "AMEX:SCHD",   title: "SCHD" },
          { proName: "AMEX:RSP",    title: "RSP" },
          { proName: "NASDAQ:QQQ",  title: "QQQ" },
          { proName: "NYSE:WMT",    title: "WMT" },
          { proName: "NASDAQ:TTWO", title: "TTWO" },
          { proName: "NYSE:TDY",    title: "TDY" },
          { proName: "NASDAQ:PKOH", title: "PKOH" },
          { proName: "NASDAQ:PANW", title: "PANW" },
          { proName: "NASDAQ:NMTC", title: "NMTC" },
          { proName: "NYSE:KMI",    title: "KMI" },
          { proName: "NASDAQ:GOOG", title: "GOOG" },
          { proName: "NASDAQ:GASS", title: "GASS" },
          { proName: "NYSE:DIS",    title: "DIS" },
          { proName: "NYSE:CVX",    title: "CVX" },
          { proName: "NASDAQ:CRWD", title: "CRWD" },
          { proName: "NYSE:C",      title: "C" },
          { proName: "NASDAQ:ARM",  title: "ARM" },
          { proName: "NASDAQ:AMZN", title: "AMZN" },
          { proName: "NYSE:ACHR",   title: "ACHR" },
          { proName: "NASDAQ:AAPL", title: "AAPL" }
        ],
        showSymbolLogo: false,
        isTransparent: true,
        displayMode: "compact",
        colorTheme: "dark",
        locale: "en"
      });
      container.appendChild(s);
    })();
  </script>
  <nav aria-label="Main navigation">
    <a href="/" class="nav-logo" aria-label="Ian Brogan — home">
      <span class="nav-logo-letters">Ian Brogan</span>
    </a>

    <button class="nav-toggle" id="nav-toggle" aria-controls="nav-menu" aria-expanded="false" aria-label="Toggle navigation">
      <span></span><span></span><span></span>
    </button>

    <ul id="nav-menu" role="list">
      {site.nav_links.map(link => (
        <li>
          <a href={link.href} class="nav-link">{link.label}</a>
        </li>
      ))}
    </ul>
  </nav>
</header>

<style>
  /* Ticker strip */
  .ticker-strip {
    width: 100%;
    overflow: hidden;
    background: rgba(201, 162, 39, 0.05);
    border-bottom: 1px solid rgba(201, 162, 39, 0.1);
    padding-block: 0.25rem;
  }
  .ticker-track {
    display: flex;
    width: max-content;
    animation: ticker-scroll 45s linear infinite;
  }
  .ticker-track:hover { animation-play-state: paused; }
  .ticker-item {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding-inline: 1.75rem;
    border-right: 1px solid rgba(201, 162, 39, 0.1);
    white-space: nowrap;
  }
  .ticker-sym {
    font-size: 0.55rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-muted);
  }
  .ticker-val {
    font-family: var(--font-display);
    font-size: 0.65rem;
    font-variation-settings: 'opsz' 12;
    font-weight: 600;
    color: var(--color-text);
    letter-spacing: -0.01em;
  }
  .ticker-chg {
    font-size: 0.55rem;
    font-weight: 700;
    letter-spacing: 0.02em;
  }
  .ticker-chg.up   { color: #22c55e; }
  .ticker-chg.down { color: #ef4444; }
  @keyframes ticker-scroll {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }
  @media (prefers-reduced-motion: reduce) {
    .ticker-track { animation: none; }
  }

  #site-nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    transition: background 0.4s cubic-bezier(0.16, 1, 0.3, 1),
                backdrop-filter 0.4s cubic-bezier(0.16, 1, 0.3, 1),
                box-shadow 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  #site-nav.scrolled {
    background: rgba(8, 8, 9, 0.85);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    box-shadow: 0 1px 0 rgba(255, 255, 255, 0.06);
  }

  nav {
    display: flex;
    align-items: center;
    max-width: 1320px;
    margin-inline: auto;
    padding-inline: clamp(1.25rem, 5vw, 4rem);
    padding-block: 0.75rem;
    gap: 2rem;
  }

  .nav-logo {
    text-decoration: none;
    margin-right: auto;
    flex-shrink: 0;
  }

  .nav-logo-letters {
    font-family: var(--font-display);
    font-size: 1.15rem;
    font-weight: 700;
    font-variation-settings: 'opsz' 36;
    color: var(--color-text);
    letter-spacing: -0.02em;
    line-height: 1;
    transition: color 0.2s;
  }
  .nav-logo:hover .nav-logo-letters { color: var(--color-gold); }

  ul {
    display: flex;
    list-style: none;
    margin: 0;
    padding: 0;
    gap: 0.25rem;
  }

  .nav-link {
    display: block;
    padding: 0.4em 0.75em;
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--color-muted);
    transition: color 0.2s;
    position: relative;
  }
  .nav-link::after {
    content: '';
    position: absolute;
    bottom: 0; left: 0.75em;
    height: 1.5px;
    width: calc(100% - 1.5em);
    background: var(--color-gold);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.28s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .nav-link:hover, .nav-link[aria-current="page"] {
    color: var(--color-text);
  }
  .nav-link:hover::after, .nav-link[aria-current="page"]::after {
    transform: scaleX(1);
  }

  .nav-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
  }
  .nav-toggle span {
    display: block;
    width: 22px;
    height: 1.5px;
    background: var(--color-ink);
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  @media (max-width: 768px) {
    .nav-toggle { display: flex; }

    ul {
      display: none;
      position: fixed;
      inset: 0;
      background: var(--color-bg);
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 0.5rem;
      z-index: 99;
    }
    ul.open { display: flex; }

    .nav-link {
      font-size: 1.25rem;
      padding: 0.75em 1.5em;
      opacity: 1;
    }
  }
</style>

<script>
  const nav = document.getElementById('site-nav')!;
  const toggle = document.getElementById('nav-toggle')!;
  const menu = document.getElementById('nav-menu')!;

  // Scroll effect
  window.addEventListener('scroll', () => {
    nav.classList.toggle('scrolled', window.scrollY > 40);
  }, { passive: true });

  // Mobile toggle
  toggle.addEventListener('click', () => {
    const open = menu.classList.toggle('open');
    toggle.setAttribute('aria-expanded', String(open));
  });

  // Close on nav click (for same-page anchors)
  menu.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      menu.classList.remove('open');
      toggle.setAttribute('aria-expanded', 'false');
    });
  });
</script>
