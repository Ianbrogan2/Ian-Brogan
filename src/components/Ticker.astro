---
interface Props {
  items?: string[];
  speed?: number;
}
const {
  items = ['MARKETS', 'DESIGN', 'CRAFT', 'VINEYARDS', 'DATA', 'MAKER', 'FILM', 'FINANCE', 'GROWTH', 'TERROIR'],
  speed = 40,
} = Astro.props;
const doubled = [...items, ...items];
---

<div class="ticker-wrap" aria-hidden="true">
  <div class="ticker-track" style={`--speed: ${speed}s`}>
    {doubled.map((item, i) => (
      <span class="ticker-item">
        {item}
        <span class="ticker-dot">·</span>
      </span>
    ))}
  </div>
</div>

<style>
  .ticker-wrap {
    overflow: hidden;
    border-top: 1px solid var(--color-bone-dk);
    border-bottom: 1px solid var(--color-bone-dk);
    background: var(--color-bone);
    padding: 0.6rem 0;
    position: relative;
    z-index: 2;
  }

  .ticker-track {
    display: flex;
    width: max-content;
    animation: ticker-scroll var(--speed, 40s) linear infinite;
  }

  .ticker-item {
    display: flex;
    align-items: center;
    gap: 1rem;
    font-family: var(--font-body);
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-mist);
    white-space: nowrap;
    padding-right: 1rem;
  }

  .ticker-dot {
    color: var(--color-gold);
    font-size: 0.8rem;
  }

  @keyframes ticker-scroll {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }

  @media (prefers-reduced-motion: reduce) {
    .ticker-track { animation: none; }
  }
</style>
