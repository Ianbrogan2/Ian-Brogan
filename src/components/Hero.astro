---
import type { SiteData } from '../lib/content';
interface Props { site: SiteData; }
const { site } = Astro.props;
const { contact } = site;
---

<section id="hero" aria-label="Introduction">

  <!-- Grain texture overlay -->
  <div class="hero-grain" aria-hidden="true"></div>

  <!-- Background layer -->
  <div class="hero-bg" aria-hidden="true">
    <div class="hero-grid"></div>
    <svg class="hero-chart" viewBox="0 0 1400 500" preserveAspectRatio="none">
      <path class="chart-path"
        d="M-10,480 C80,460 140,430 220,390 C300,350 340,370 420,320
           C500,270 560,250 660,200 C760,150 820,185 920,140
           C1020,95 1090,115 1190,70 C1280,30 1350,40 1410,20" />
    </svg>
  </div>

  <div class="hero-inner container">

    <!-- Identity kicker -->
    <div class="hero-kicker">
      <span class="kicker-rule" aria-hidden="true"></span>
      Student &nbsp;·&nbsp; Leader &nbsp;·&nbsp; Investor
    </div>

    <!-- Name · the headline -->
    <h1 class="hero-name">
      <span class="hl-wrap"><span class="hl-line hl-1">Ian</span></span>
      <span class="hl-wrap"><span class="hl-line hl-2">Brogan.</span></span>
    </h1>

    <!-- Value prop + trajectory · scholarship-legible in one read -->
    <div class="hero-essay">
      <p class="hero-valueprop">
        Senior heading into Business Economics. Studio Director leading a
        six-figure rebrand of my school's broadcast program, with a 4.22 GPA
        and the Golden State Seal Merit Diploma behind it.
      </p>
      <p class="hero-trajectory">
        Investing since age ten, building since freshman year, aimed at a
        career in fund management.
      </p>
    </div>

    <!-- CTAs · magnetic on hover -->
    <div class="hero-cta">
      <a href="/achievements" class="btn btn-primary btn-mag">My Achievements</a>
      <a href="/about" class="btn btn-outline-light btn-mag">My Story</a>
      <a href="/resume" class="btn btn-ghost">My Résumé</a>
    </div>

    <!-- Stats bar -->
    <div class="hero-stats" aria-label="Key facts">
      <div class="hstat">
        <span class="hstat-num" data-count="7">7</span>
        <span class="hstat-label">Years in markets</span>
      </div>
      <div class="hstat-div" aria-hidden="true"></div>
      <div class="hstat">
        <span class="hstat-num" data-count="17">17</span>
        <span class="hstat-label">Years old</span>
      </div>
      <div class="hstat-div" aria-hidden="true"></div>
      <div class="hstat">
        <span class="hstat-num">Top 14%</span>
        <span class="hstat-label">Class rank, 84 of 632</span>
      </div>
    </div>

  </div>

  <!-- Scroll cue -->
  <div class="scroll-cue" aria-hidden="true">
    <div class="scroll-cue-line"><div class="scroll-cue-bar"></div></div>
    <span>Scroll</span>
  </div>
</section>

<style>
  #hero {
    position: relative;
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
    background: var(--color-bg);
    overflow: hidden;
  }

  /* ── Grain overlay ───────────────────────────────────────── */
  .hero-grain {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    opacity: 0.4;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.06'/%3E%3C/svg%3E");
    background-size: 180px 180px;
    background-repeat: repeat;
  }

  /* ── Background ─────────────────────────────────────────── */
  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }

  .hero-grid {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle, rgba(201, 162, 39, 0.08) 1px, transparent 1px);
    background-size: 44px 44px;
    animation: grid-fade 2s var(--ease-expo) 0.2s both;
  }

  .hero-chart {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    overflow: visible;
  }

  .chart-path {
    fill: none;
    stroke: var(--color-gold);
    stroke-width: 1.5;
    opacity: 0.1;
    stroke-dasharray: 3000;
    stroke-dashoffset: 3000;
    animation: chart-draw 3s var(--ease-expo) 0.8s both;
  }

  /* ── Content ─────────────────────────────────────────────── */
  .hero-inner {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding-top: 8rem;
    padding-bottom: 6rem;
    position: relative;
    z-index: 2;
    max-width: 920px;
  }

  /* ── Kicker ─────────────────────────────────────────────── */
  .hero-kicker {
    display: flex;
    align-items: center;
    gap: 1rem;
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-gold);
    margin-bottom: 1.5rem;
    opacity: 0;
    animation: fade-up 0.7s var(--ease-expo) 0.2s both;
  }
  .kicker-rule {
    display: block;
    width: 2rem;
    height: 1.5px;
    background: var(--color-gold);
    flex-shrink: 0;
  }

  /* ── Name ────────────────────────────────────────────────── */
  .hero-name {
    font-family: var(--font-display);
    font-size: clamp(5rem, 14vw, 11rem);
    font-variation-settings: 'opsz' 144;
    font-weight: 900;
    line-height: 0.9;
    letter-spacing: -0.04em;
    color: var(--color-text);
    margin: 0 0 2.5rem;
  }

  .hl-wrap {
    display: block;
    overflow: hidden;
    padding-bottom: 0.2em;
  }
  .hl-line {
    display: block;
    transform: translateY(110%);
  }
  .hl-1 { animation: line-rise 1s var(--ease-quart) 0.35s both; }
  .hl-2 { animation: line-rise 1s var(--ease-quart) 0.52s both; }

  /* ── Value prop + trajectory ─────────────────────────────── */
  .hero-essay {
    max-width: 56ch;
    margin-bottom: 2.5rem;
    opacity: 0;
    animation: fade-up 0.9s var(--ease-expo) 0.9s both;
  }
  .hero-valueprop {
    font-size: clamp(1.05rem, 1.7vw, 1.35rem);
    line-height: 1.6;
    color: var(--color-text);
    font-weight: 400;
    max-width: none;
  }
  .hero-trajectory {
    font-size: clamp(0.9rem, 1.3vw, 1.02rem);
    line-height: 1.7;
    color: rgba(237, 232, 223, 0.7);
    font-weight: 300;
    max-width: none;
    margin-top: 0.9em;
  }

  /* ── CTAs ────────────────────────────────────────────────── */
  .hero-cta {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 3rem;
    opacity: 0;
    animation: fade-up 0.8s var(--ease-expo) 1.1s both;
  }

  /* Magnetic wrapper · js adds inline transform */
  .btn-mag {
    transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1), background 0.2s, color 0.2s, border-color 0.2s;
    display: inline-block;
  }

  /* ── Stats ───────────────────────────────────────────────── */
  .hero-stats {
    display: flex;
    align-items: center;
    gap: 2.5rem;
    flex-wrap: wrap;
    padding: 1.5rem 0;
    border-top: 1px solid var(--color-border);
    opacity: 0;
    animation: fade-up 0.8s var(--ease-expo) 1.25s both;
  }

  .hstat { display: flex; flex-direction: column; gap: 0.35rem; }
  .hstat-num {
    font-family: var(--font-display);
    font-size: clamp(1.3rem, 2.2vw, 1.8rem);
    font-variation-settings: 'opsz' 48;
    font-weight: 700;
    letter-spacing: -0.03em;
    color: var(--color-text);
    line-height: 1;
  }
  .hstat-label {
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-muted);
  }
  .hstat-div {
    width: 1px;
    height: 2.25rem;
    background: var(--color-border-lt);
    flex-shrink: 0;
  }

  /* ── Scroll cue ─────────────────────────────────────────── */
  .scroll-cue {
    position: absolute;
    bottom: 2rem;
    left: clamp(1.25rem, 5vw, 4rem);
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.58rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-muted);
    z-index: 2;
    opacity: 0;
    animation: fade-up 0.8s var(--ease-expo) 1.6s both;
  }
  .scroll-cue-line {
    width: 1px;
    height: 36px;
    background: var(--color-border-lt);
    overflow: hidden;
    position: relative;
  }
  .scroll-cue-bar {
    position: absolute;
    top: 0; width: 100%; height: 50%;
    background: var(--color-gold);
    animation: scroll-drop 2s var(--ease-expo) infinite 2s;
  }

  /* ── Keyframes ───────────────────────────────────────────── */
  @keyframes fade-up {
    from { opacity: 0; transform: translateY(1.5rem); }
    to   { opacity: 1; transform: none; }
  }
  @keyframes line-rise {
    from { transform: translateY(110%); }
    to   { transform: translateY(0); }
  }
  @keyframes chart-draw {
    to { stroke-dashoffset: 0; }
  }
  @keyframes grid-fade {
    from { opacity: 0; } to { opacity: 1; }
  }
  @keyframes scroll-drop {
    0%   { transform: translateY(-100%); }
    100% { transform: translateY(200%); }
  }

  /* ── Reduced motion ──────────────────────────────────────── */
  @media (prefers-reduced-motion: reduce) {
    .hero-kicker, .hl-line, .hero-essay, .hero-cta,
    .hero-stats, .scroll-cue {
      opacity: 1; transform: none; animation: none;
    }
    .chart-path { stroke-dashoffset: 0; animation: none; }
    .scroll-cue-bar { animation: none; }
  }

  /* ── Responsive ──────────────────────────────────────────── */
  @media (max-width: 900px) {
    .hstat-div  { display: none; }
    .hero-stats { gap: 1.5rem; }
  }
  @media (max-width: 600px) {
    .hero-inner { padding-top: 7.5rem; }
    .hero-stats { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem 1.5rem; }
    .hero-kicker { display: none; }
  }
</style>

<script>
  (() => {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    // ── Countup for stats ─────────────────────────────────────
    document.querySelectorAll<HTMLElement>('.hstat-num[data-count]').forEach(el => {
      const target = parseInt(el.dataset.count || '0');
      let start: number | null = null;
      const duration = 1400;

      function easeOut(t: number) { return 1 - Math.pow(1 - t, 3); }

      setTimeout(() => {
        function step(ts: number) {
          if (!start) start = ts;
          const progress = Math.min((ts - start) / duration, 1);
          el.textContent = String(Math.round(easeOut(progress) * target));
          if (progress < 1) requestAnimationFrame(step);
          else el.textContent = String(target);
        }
        requestAnimationFrame(step);
      }, 1600); // start after hero animates in
    });

    // ── Magnetic buttons ─────────────────────────────────────
    document.querySelectorAll<HTMLElement>('.btn-mag').forEach(btn => {
      const strength = 0.35;
      btn.addEventListener('mousemove', (e: MouseEvent) => {
        const r = btn.getBoundingClientRect();
        const x = (e.clientX - r.left - r.width  / 2) * strength;
        const y = (e.clientY - r.top  - r.height / 2) * strength;
        btn.style.transform = `translate(${x}px, ${y}px)`;
      });
      btn.addEventListener('mouseleave', () => {
        btn.style.transform = '';
      });
    });
  })();
</script>
