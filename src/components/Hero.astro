---
import type { SiteData } from '../lib/content';
interface Props { site: SiteData; }
const { site } = Astro.props;
const { contact } = site;
---

<section id="hero" aria-label="Introduction">
  <!-- Background layer -->
  <div class="hero-bg" aria-hidden="true">
    <div class="hero-grid"></div>
    <svg class="hero-chart" viewBox="0 0 1400 500" preserveAspectRatio="none">
      <path class="chart-path"
        d="M-10,480 C80,460 140,430 220,390 C300,350 340,370 420,320
           C500,270 560,250 660,200 C760,150 820,185 920,140
           C1020,95 1090,115 1190,70 C1280,30 1350,40 1410,20" />
    </svg>
    <div class="data-chip chip-a" aria-hidden="true">
      <span class="chip-dot chip-dot--green"></span>S&amp;P 500
    </div>
    <div class="data-chip chip-b" aria-hidden="true">
      <span class="chip-dot chip-dot--gold"></span>ECONOMICS
    </div>
    <div class="data-chip chip-c" aria-hidden="true">
      <span class="chip-dot chip-dot--green"></span>MARKETS ▲
    </div>
  </div>

  <div class="hero-inner container">

    <!-- Identity kicker -->
    <div class="hero-kicker">
      <span class="kicker-rule" aria-hidden="true"></span>
      Finance &nbsp;·&nbsp; Economics &nbsp;·&nbsp; Markets
    </div>

    <!-- Name — the headline -->
    <h1 class="hero-name">
      <span class="hl-wrap"><span class="hl-line hl-1">Ian</span></span>
      <span class="hl-wrap"><span class="hl-line hl-2">Brogan.</span></span>
    </h1>

    <!-- Short bio essay -->
    <div class="hero-essay">
      <p>
        I'm seventeen, self-taught in finance and markets, and already operating
        at a level most people reach years from now. I've spent seven years
        studying economics, financial statements, and capital allocation — not
        for a grade, but because this is the domain I intend to master.
      </p>
      <p>
        I've been trusted to lead real programs and real budgets. I've built
        things with my hands and built models on a screen. The range isn't a
        distraction — it's the edge. This site is how you get to know me.
      </p>
    </div>

    <!-- CTAs -->
    <div class="hero-cta">
      <a href="/about" class="btn btn-primary">My Story</a>
      <a href="/journey" class="btn btn-outline-light">See My Journey</a>
      <a href={`mailto:${contact.email}`} class="btn btn-ghost">Get in Touch</a>
    </div>

    <!-- Stats bar -->
    <div class="hero-stats" aria-label="Key facts">
      <div class="hstat">
        <span class="hstat-num">7</span>
        <span class="hstat-label">Years studying markets</span>
      </div>
      <div class="hstat-div" aria-hidden="true"></div>
      <div class="hstat">
        <span class="hstat-num">~$100K</span>
        <span class="hstat-label">Budget entrusted</span>
      </div>
      <div class="hstat-div" aria-hidden="true"></div>
      <div class="hstat">
        <span class="hstat-num">Lead</span>
        <span class="hstat-label">Studio Director</span>
      </div>
      <div class="hstat-div" aria-hidden="true"></div>
      <div class="hstat">
        <span class="hstat-num">17</span>
        <span class="hstat-label">Years old</span>
      </div>
    </div>

  </div>

  <!-- Scroll cue -->
  <div class="scroll-cue" aria-hidden="true">
    <div class="scroll-cue-line"><div class="scroll-cue-bar"></div></div>
    <span>Scroll</span>
  </div>
</section>

<style>
  #hero {
    position: relative;
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
    background: var(--color-bg);
    overflow: hidden;
  }

  /* ── Background ─────────────────────────────────────────── */
  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }

  .hero-grid {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle, rgba(201, 162, 39, 0.1) 1px, transparent 1px);
    background-size: 44px 44px;
    animation: grid-fade 2s var(--ease-expo) 0.2s both;
  }

  .hero-chart {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    overflow: visible;
  }

  .chart-path {
    fill: none;
    stroke: var(--color-gold);
    stroke-width: 1.5;
    opacity: 0.14;
    stroke-dasharray: 3000;
    stroke-dashoffset: 3000;
    animation: chart-draw 3s var(--ease-expo) 0.8s both;
  }

  .data-chip {
    position: absolute;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.35rem 0.75rem;
    background: var(--color-elevated);
    border: 1px solid var(--color-border-lt);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(237, 232, 223, 0.7);
    opacity: 0;
    animation: chip-in 0.6s var(--ease-expo) both, chip-float 7s ease-in-out infinite;
  }
  .chip-a { top: 25%; right: 8%;  animation-delay: 1.4s, 2s; }
  .chip-b { top: 50%; right: 12%; animation-delay: 1.7s, 2.4s; }
  .chip-c { top: 38%; right: 4%;  animation-delay: 2s, 2.8s; }

  .chip-dot { width: 5px; height: 5px; border-radius: 50%; flex-shrink: 0; }
  .chip-dot--green { background: var(--color-green); box-shadow: 0 0 5px var(--color-green); }
  .chip-dot--gold  { background: var(--color-gold);  box-shadow: 0 0 5px var(--color-gold); }

  /* ── Content ─────────────────────────────────────────────── */
  .hero-inner {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding-top: 8rem;
    padding-bottom: 6rem;
    position: relative;
    z-index: 1;
    max-width: 900px;
  }

  /* ── Kicker ─────────────────────────────────────────────── */
  .hero-kicker {
    display: flex;
    align-items: center;
    gap: 1rem;
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-gold);
    margin-bottom: 1.5rem;
    opacity: 0;
    animation: fade-up 0.7s var(--ease-expo) 0.2s both;
  }
  .kicker-rule {
    display: block;
    width: 2rem;
    height: 1.5px;
    background: var(--color-gold);
    flex-shrink: 0;
  }

  /* ── Name ────────────────────────────────────────────────── */
  .hero-name {
    font-family: var(--font-display);
    font-size: clamp(5rem, 14vw, 11rem);
    font-variation-settings: 'opsz' 144;
    font-weight: 900;
    line-height: 0.9;
    letter-spacing: -0.04em;
    color: var(--color-text);
    margin: 0 0 2.5rem;
  }

  .hl-wrap {
    display: block;
    overflow: hidden;
    padding-bottom: 0.06em;
  }
  .hl-line {
    display: block;
    transform: translateY(110%);
  }
  .hl-1 { animation: line-rise 1s var(--ease-quart) 0.35s both; }
  .hl-2 { animation: line-rise 1s var(--ease-quart) 0.52s both; }

  /* ── Essay ───────────────────────────────────────────────── */
  .hero-essay {
    max-width: 58ch;
    margin-bottom: 2.5rem;
    opacity: 0;
    animation: fade-up 0.9s var(--ease-expo) 0.9s both;
  }
  .hero-essay p {
    font-size: clamp(0.95rem, 1.4vw, 1.1rem);
    line-height: 1.75;
    color: rgba(237, 232, 223, 0.75);
    font-weight: 300;
    max-width: none;
  }
  .hero-essay p + p { margin-top: 1em; }

  /* ── CTAs ────────────────────────────────────────────────── */
  .hero-cta {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 3rem;
    opacity: 0;
    animation: fade-up 0.8s var(--ease-expo) 1.1s both;
  }

  /* ── Stats ───────────────────────────────────────────────── */
  .hero-stats {
    display: flex;
    align-items: center;
    gap: 2.5rem;
    flex-wrap: wrap;
    padding: 1.5rem 0;
    border-top: 1px solid var(--color-border);
    opacity: 0;
    animation: fade-up 0.8s var(--ease-expo) 1.25s both;
  }

  .hstat { display: flex; flex-direction: column; gap: 0.35rem; }
  .hstat-num {
    font-family: var(--font-display);
    font-size: clamp(1.3rem, 2.2vw, 1.8rem);
    font-variation-settings: 'opsz' 48;
    font-weight: 700;
    letter-spacing: -0.03em;
    color: var(--color-text);
    line-height: 1;
  }
  .hstat-label {
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-muted);
  }
  .hstat-div {
    width: 1px;
    height: 2.25rem;
    background: var(--color-border-lt);
    flex-shrink: 0;
  }

  /* ── Scroll cue ─────────────────────────────────────────── */
  .scroll-cue {
    position: absolute;
    bottom: 2rem;
    left: clamp(1.25rem, 5vw, 4rem);
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.58rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-muted);
    z-index: 1;
    opacity: 0;
    animation: fade-up 0.8s var(--ease-expo) 1.6s both;
  }
  .scroll-cue-line {
    width: 1px;
    height: 36px;
    background: var(--color-border-lt);
    overflow: hidden;
    position: relative;
  }
  .scroll-cue-bar {
    position: absolute;
    top: 0; width: 100%; height: 50%;
    background: var(--color-gold);
    animation: scroll-drop 2s var(--ease-expo) infinite 2s;
  }

  /* ── Keyframes ───────────────────────────────────────────── */
  @keyframes fade-up {
    from { opacity: 0; transform: translateY(1.5rem); }
    to   { opacity: 1; transform: none; }
  }
  @keyframes line-rise {
    from { transform: translateY(110%); }
    to   { transform: translateY(0); }
  }
  @keyframes chart-draw {
    to { stroke-dashoffset: 0; }
  }
  @keyframes grid-fade {
    from { opacity: 0; } to { opacity: 1; }
  }
  @keyframes chip-in {
    from { opacity: 0; transform: translateX(1.5rem); }
    to   { opacity: 1; transform: none; }
  }
  @keyframes chip-float {
    0%, 100% { transform: translateY(0); }
    50%       { transform: translateY(-10px); }
  }
  @keyframes scroll-drop {
    0%   { transform: translateY(-100%); }
    100% { transform: translateY(200%); }
  }

  /* ── Reduced motion ──────────────────────────────────────── */
  @media (prefers-reduced-motion: reduce) {
    .hero-kicker, .hl-line, .hero-essay, .hero-cta,
    .hero-stats, .scroll-cue, .data-chip {
      opacity: 1; transform: none; animation: none;
    }
    .chart-path { stroke-dashoffset: 0; animation: none; }
    .scroll-cue-bar { animation: none; }
  }

  /* ── Responsive ──────────────────────────────────────────── */
  @media (max-width: 900px) {
    .data-chip  { display: none; }
    .hstat-div  { display: none; }
    .hero-stats { gap: 1.5rem; }
  }
  @media (max-width: 600px) {
    .hero-inner { padding-top: 6rem; }
    .hero-stats { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem 1.5rem; }
    .hero-cta .btn:last-child { display: none; }
  }
</style>

<script>
  (() => {
    // Skip lock if user prefers reduced motion
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    // Chart draws over 3s starting at 0.8s delay → done at ~4s. Lock until 4.2s.
    const LOCK_UNTIL = Date.now() + 4200;
    let locked = true;

    const stopScroll = (e: Event) => {
      if (locked) e.preventDefault();
    };

    window.addEventListener('wheel',      stopScroll, { passive: false });
    window.addEventListener('touchmove',  stopScroll, { passive: false });
    window.addEventListener('keydown', (e: KeyboardEvent) => {
      if (locked && ['ArrowDown','ArrowUp','Space','PageDown','PageUp'].includes(e.code)) {
        e.preventDefault();
      }
    });

    setTimeout(() => {
      locked = false;
    }, LOCK_UNTIL - Date.now());
  })();
</script>
