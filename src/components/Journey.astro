---
import type { JourneyData, JourneyMilestone } from '../lib/content';
interface Props { data: JourneyData; }
const { data } = Astro.props;

const { milestones, noise_points, chart, present_age } = data;

type Point = { age: number; value: number; isMilestone: boolean; milestone?: JourneyMilestone };

const allPoints: Point[] = [
  ...milestones.map(m => ({ age: m.age, value: m.value, isMilestone: true, milestone: m })),
  ...noise_points.map(n => ({ age: n.age, value: n.value, isMilestone: false })),
].sort((a, b) => a.age - b.age);

const W = 1200, H = 480;
const gLeft = 80, gRight = 1160, gTop = 40, gBottom = 420;
const gW = gRight - gLeft, gH = gBottom - gTop;
const xMin = chart.x_min_age, xMax = chart.x_max_age;
const yMin = 0, yMax = 3200;

function xOf(age: number) { return gLeft + (age - xMin) / (xMax - xMin) * gW; }
function yOf(value: number) { return gBottom - (value - yMin) / (yMax - yMin) * gH; }

const presentIdx = allPoints.findIndex(p => p.age >= present_age);
const pastPoints  = allPoints.slice(0, presentIdx + 1);
const futurePoints = allPoints.slice(presentIdx);

function smoothPath(pts: Point[]): string {
  if (pts.length < 2) return '';
  const coords = pts.map(p => ({ x: xOf(p.age), y: yOf(p.value) }));
  let d = `M ${coords[0].x},${coords[0].y}`;
  for (let i = 0; i < coords.length - 1; i++) {
    const p0 = coords[Math.max(0, i - 1)];
    const p1 = coords[i];
    const p2 = coords[i + 1];
    const p3 = coords[Math.min(coords.length - 1, i + 2)];
    const cp1x = p1.x + (p2.x - p0.x) / 6;
    const cp1y = p1.y + (p2.y - p0.y) / 6;
    const cp2x = p2.x - (p3.x - p1.x) / 6;
    const cp2y = p2.y - (p3.y - p1.y) / 6;
    d += ` C ${cp1x.toFixed(2)},${cp1y.toFixed(2)} ${cp2x.toFixed(2)},${cp2y.toFixed(2)} ${p2.x.toFixed(2)},${p2.y.toFixed(2)}`;
  }
  return d;
}

const pastPath   = smoothPath(pastPoints);
const futurePath = smoothPath(futurePoints);

const milestoneCoords = milestones.map(m => ({
  ...m,
  x: xOf(m.age),
  y: yOf(m.value),
}));

const gridAges   = chart.gridline_ages.filter((a: number) => a >= xMin && a <= xMax);
const gridValues = chart.gridline_values.filter((v: number) => v >= yMin && v <= yMax);

// Milestone data as JSON for the client script
const milestoneJSON = JSON.stringify(milestones.map(m => ({ label: m.label, description: m.description, type: m.type, age: m.age })));
---

<section id="journey" class="section" aria-labelledby="journey-heading">
  <div class="container">
    <!-- Graph -->
    <div class="journey-graph-wrap" id="journey-section">
      <svg
        id="journey-svg"
        viewBox={`0 0 ${W} ${H}`}
        preserveAspectRatio="xMidYMid meet"
        role="img"
        aria-label="Ian Brogan life timeline as an equity curve chart"
      >
        <!-- Background -->
        <rect width={W} height={H} fill="var(--color-elevated)" rx="2"/>

        <defs>
          <linearGradient id="future-grad" x1="0%" y1="0%" x2="100%" y2="0%">
            <stop offset="0%" stop-color="var(--color-gold)"/>
            <stop offset="100%" stop-color="rgba(201,162,39,0.35)"/>
          </linearGradient>
        </defs>

        <!-- Y gridlines -->
        {gridValues.map((v: number) => (
          <g class="grid-row">
            <line
              x1={gLeft} y1={yOf(v)} x2={gRight} y2={yOf(v)}
              stroke="rgba(237,232,223,0.06)" stroke-width="1"
            />
            <text
              x={gLeft - 8} y={yOf(v)}
              text-anchor="end" dominant-baseline="middle"
              fill="rgba(237,232,223,0.3)" font-size="11" font-family="var(--font-body)"
            >{v === 0 ? '' : v.toLocaleString()}</text>
          </g>
        ))}

        <!-- X gridlines / age labels -->
        {gridAges.map((a: number) => (
          <g class="grid-col">
            <line
              x1={xOf(a)} y1={gTop} x2={xOf(a)} y2={gBottom + 10}
              stroke="rgba(237,232,223,0.06)" stroke-width="1"
            />
            <text
              x={xOf(a)} y={gBottom + 22}
              text-anchor="middle"
              fill="rgba(237,232,223,0.3)" font-size="11" font-family="var(--font-body)"
            >{a}</text>
          </g>
        ))}

        <!-- Axis labels -->
        <text x={gLeft - 8} y={gTop - 14} text-anchor="start"
          fill="rgba(237,232,223,0.4)" font-size="11" font-family="var(--font-body)"
          letter-spacing="1">GROWTH</text>
        <text x={gRight + 8} y={gBottom + 22} text-anchor="end"
          fill="rgba(237,232,223,0.4)" font-size="11" font-family="var(--font-body)"
          letter-spacing="1">AGE</text>

        <!-- Present-line vertical marker -->
        <line
          x1={xOf(present_age)} y1={gTop} x2={xOf(present_age)} y2={gBottom}
          stroke="var(--color-gold)" stroke-width="1" stroke-dasharray="4 4" opacity="0.5"
        />
        <text x={xOf(present_age) + 6} y={gTop + 18}
          fill="var(--color-gold)" font-size="10" font-family="var(--font-body)"
          letter-spacing="1">NOW</text>

        <!-- Future path -->
        <path
          id="journey-future-path"
          d={futurePath}
          fill="none"
          stroke="url(#future-grad)"
          stroke-width="2.5"
          stroke-dasharray="8 5"
          stroke-linecap="round"
          opacity="0.9"
        />

        <!-- Past path -->
        <path
          id="journey-past-path"
          d={pastPath}
          fill="none"
          stroke="var(--color-gold)"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
        />

        <!-- Milestone markers -->
        {milestoneCoords.map((m, i) => (
          <g
            class="milestone-marker"
            data-index={i}
            data-age={m.age}
            data-type={m.type}
            style="opacity:0; cursor:pointer"
            role="button"
            tabindex="0"
            aria-label={`${m.label}: ${m.description}`}
          >
            <circle cx={m.x} cy={m.y} r="14"
              fill="transparent"
            />
            <circle cx={m.x} cy={m.y} r="7"
              fill={m.type === 'current' ? 'var(--color-gold)' : m.type === 'future' ? 'var(--color-elevated)' : 'var(--color-elevated)'}
              stroke={m.type === 'current' ? 'var(--color-gold)' : m.type === 'future' ? 'rgba(201,162,39,0.5)' : 'var(--color-gold)'}
              stroke-width="2"
            />
            <circle cx={m.x} cy={m.y} r="2.5"
              fill={m.type === 'future' ? 'rgba(201,162,39,0.5)' : 'var(--color-text)'}
            />
          </g>
        ))}
      </svg>
    </div>

    <!-- Description panel — updates when a milestone is clicked/tapped -->
    <div id="milestone-panel" class="milestone-panel" aria-live="polite">
      <div class="milestone-panel-empty">
        <span>← Tap any point on the chart to see details</span>
      </div>
      <div class="milestone-panel-content" hidden>
        <div class="mp-meta">
          <span class="mp-age" id="mp-age"></span>
          <span class="mp-type" id="mp-type"></span>
        </div>
        <h3 class="mp-label" id="mp-label"></h3>
        <p class="mp-desc" id="mp-desc"></p>
      </div>
    </div>

    <!-- Accessible fallback (desktop) -->
    <details class="journey-fallback">
      <summary>▸ View all milestones as a list</summary>
      <table>
        <caption>Ian Brogan's life milestones</caption>
        <thead><tr><th>Age</th><th>Milestone</th><th>Description</th><th>Phase</th></tr></thead>
        <tbody>
          {milestones.map(m => (
            <tr>
              <td>{m.age}</td>
              <td>{m.label}</td>
              <td>{m.description}</td>
              <td>{m.type === 'current' ? 'Present' : m.type === 'future' ? 'Projected' : 'Past'}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </details>

    <!-- Mobile timeline list (replaces chart on small screens) -->
    <div class="journey-mobile-list" aria-label="Life milestones timeline">
      {milestones.map((m) => (
        <div class={`jml-item jml-item--${m.type}`}>
          <div class="jml-spine">
            <div class="jml-dot"></div>
            <div class="jml-line"></div>
          </div>
          <div class="jml-body">
            <div class="jml-meta">
              <span class="jml-age">Age {m.age}</span>
              <span class="jml-tag">{m.type === 'current' ? 'Now' : m.type === 'future' ? 'Projected' : 'Past'}</span>
            </div>
            <h3 class="jml-label">{m.label}</h3>
            <p class="jml-desc">{m.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  #journey { background: var(--color-surface); }

  .journey-header {
    max-width: 700px;
    margin-bottom: clamp(2.5rem, 4vw, 4rem);
  }
  .journey-header h2 { margin-bottom: 1rem; }

  .journey-graph-wrap {
    position: relative;
    width: 100%;
    border: 1px solid var(--color-border);
    overflow: hidden;
    border-radius: 2px;
  }

  #journey-svg {
    width: 100%;
    height: auto;
    display: block;
    cursor: crosshair;
  }

  .milestone-marker { transition: opacity 0.5s var(--ease-expo); }
  .milestone-marker:focus { outline: none; }
  .milestone-marker:hover circle:nth-child(2),
  .milestone-marker:focus circle:nth-child(2) {
    filter: brightness(1.3);
  }
  .milestone-marker.active circle:nth-child(2) {
    stroke-width: 3;
  }

  /* Description panel */
  .milestone-panel {
    margin-top: 1.5rem;
    min-height: 6rem;
    padding: 1.5rem 2rem;
    background: var(--color-elevated);
    border: 1px solid var(--color-border);
    border-left: 3px solid var(--color-gold);
    transition: border-color 0.3s;
  }

  .milestone-panel-empty {
    display: flex;
    align-items: center;
    height: 3rem;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-muted);
  }

  .milestone-panel-content { }

  .mp-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 0.75rem;
  }
  .mp-age {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-gold);
  }
  .mp-type {
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-muted);
    border: 1px solid var(--color-border-lt);
    padding: 0.15em 0.5em;
  }
  .mp-label {
    font-family: var(--font-display);
    font-size: clamp(1.1rem, 2vw, 1.5rem);
    font-variation-settings: 'opsz' 24;
    font-weight: 700;
    color: var(--color-text);
    margin: 0 0 0.5rem;
    letter-spacing: -0.02em;
  }
  .mp-desc {
    font-size: 0.95rem;
    line-height: 1.65;
    color: rgba(237,232,223,0.75);
    margin: 0;
    max-width: 70ch;
  }

  /* Fallback table */
  .journey-fallback {
    margin-top: 2.5rem;
  }
  .journey-fallback summary {
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-muted);
    cursor: pointer;
    padding: 0.5rem 0;
    border-bottom: 1px solid var(--color-border);
  }
  .journey-fallback table {
    width: 100%;
    border-collapse: collapse;
    margin-top: 1.5rem;
    font-size: 0.85rem;
  }
  .journey-fallback th {
    text-align: left;
    font-size: 0.65rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-muted);
    padding: 0.5rem 0.75rem;
    border-bottom: 1px solid var(--color-border);
  }
  .journey-fallback td {
    padding: 0.6rem 0.75rem;
    border-bottom: 1px solid var(--color-border);
    vertical-align: top;
    color: var(--color-text-dim);
  }
  .journey-fallback td:first-child { white-space: nowrap; font-weight: 600; color: var(--color-text); }
  .journey-fallback caption {
    caption-side: top;
    text-align: left;
    font-size: 0.8rem;
    color: var(--color-muted);
    margin-bottom: 0.75rem;
  }

  /* ── Mobile timeline list ─────────────────────────────────── */
  .journey-mobile-list { display: none; }

  @media (max-width: 768px) {
    .journey-graph-wrap,
    .milestone-panel,
    .journey-fallback { display: none !important; }

    .journey-mobile-list {
      display: flex;
      flex-direction: column;
    }

    .jml-item {
      display: flex;
      gap: 1rem;
    }

    .jml-spine {
      display: flex;
      flex-direction: column;
      align-items: center;
      flex-shrink: 0;
      width: 20px;
    }

    .jml-dot {
      width: 10px;
      height: 10px;
      border-radius: 50%;
      flex-shrink: 0;
      margin-top: 0.3rem;
      background: var(--color-gold);
      border: 2px solid var(--color-bg);
      box-shadow: 0 0 0 1px var(--color-gold);
    }
    .jml-item--future .jml-dot {
      background: transparent;
      border-color: rgba(201,162,39,0.4);
      box-shadow: 0 0 0 1px rgba(201,162,39,0.3);
    }
    .jml-item--current .jml-dot {
      background: var(--color-gold);
      box-shadow: 0 0 8px var(--color-gold);
    }

    .jml-line {
      flex: 1;
      width: 1px;
      background: var(--color-border);
      margin-block: 4px;
    }
    .jml-item:last-child .jml-line { display: none; }

    .jml-body {
      padding-bottom: 1.75rem;
    }

    .jml-meta {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      margin-bottom: 0.3rem;
    }

    .jml-age {
      font-size: 0.65rem;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--color-gold);
    }

    .jml-tag {
      font-size: 0.6rem;
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--color-muted);
      padding: 0.15em 0.5em;
      border: 1px solid var(--color-border);
    }
    .jml-item--current .jml-tag {
      color: var(--color-gold);
      border-color: rgba(201,162,39,0.4);
    }

    .jml-label {
      font-family: var(--font-display);
      font-size: 1rem;
      font-variation-settings: 'opsz' 24;
      color: var(--color-text);
      margin: 0 0 0.4rem;
      line-height: 1.2;
    }
    .jml-item--future .jml-label { color: var(--color-text-dim); }

    .jml-desc {
      font-size: 0.82rem;
      color: var(--color-text-dim);
      line-height: 1.65;
      margin: 0;
    }
  }
</style>

<script define:vars={{ milestoneJSON, present_age }}>
  const milestoneData = JSON.parse(milestoneJSON);

  const section      = document.getElementById('journey-section');
  const pastPathEl   = document.getElementById('journey-past-path');
  const futurePathEl = document.getElementById('journey-future-path');
  const markers      = Array.from(document.querySelectorAll('.milestone-marker'));

  const panel        = document.getElementById('milestone-panel');
  const panelEmpty   = panel?.querySelector('.milestone-panel-empty');
  const panelContent = panel?.querySelector('.milestone-panel-content');
  const mpAge        = document.getElementById('mp-age');
  const mpType       = document.getElementById('mp-type');
  const mpLabel      = document.getElementById('mp-label');
  const mpDesc       = document.getElementById('mp-desc');

  // ── Description panel ────────────────────────────────────
  function showMilestone(index) {
    const m = milestoneData[index];
    if (!m || !panel) return;

    if (panelEmpty) panelEmpty.hidden = true;
    if (panelContent) panelContent.hidden = false;
    if (mpAge)   mpAge.textContent   = `Age ${m.age}`;
    if (mpType)  mpType.textContent  = m.type === 'current' ? 'Present' : m.type === 'future' ? 'Projected' : 'Past';
    if (mpLabel) mpLabel.textContent = m.label;
    if (mpDesc)  mpDesc.textContent  = m.description;

    if (panel) {
      panel.style.borderLeftColor = m.type === 'future' ? 'var(--color-green)' : 'var(--color-gold)';
    }

    markers.forEach(el => el.classList.remove('active'));
    markers[index]?.classList.add('active');

    if (window.innerWidth < 768) {
      panel.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    }
  }

  markers.forEach((marker, i) => {
    marker.addEventListener('click',      () => showMilestone(i));
    marker.addEventListener('touchstart', (e) => { e.preventDefault(); showMilestone(i); }, { passive: false });
    marker.addEventListener('keydown',    (e) => { if (e.key === 'Enter' || e.key === ' ') showMilestone(i); });
  });

  // ── Chart animation ───────────────────────────────────────
  if (!pastPathEl || !futurePathEl || !section) return;

  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (prefersReduced) {
    // Show everything immediately
    pastPathEl.style.strokeDasharray = 'none';
    pastPathEl.style.strokeDashoffset = '0';
    markers.forEach(m => { m.style.opacity = '1'; });
    return;
  }

  // Hide paths initially with a large number — lengths measured after first paint
  pastPathEl.style.strokeDasharray  = '9999';
  pastPathEl.style.strokeDashoffset = '9999';
  futurePathEl.style.strokeDasharray  = '9999';
  futurePathEl.style.strokeDashoffset = '9999';
  markers.forEach(m => { m.style.opacity = '0'; });

  const PAST_DURATION   = 2200;
  const FUTURE_DELAY    = 1800;
  const FUTURE_DURATION = 1600;

  function easeOut(t) { return 1 - Math.pow(1 - t, 3); }

  let started = false;

  function startAnimation() {
    if (started) return;
    started = true;

    // Measure AFTER the element is visible so getTotalLength() returns real values
    requestAnimationFrame(() => {
      const pastLen   = pastPathEl.getTotalLength();
      const futureLen = futurePathEl.getTotalLength();

      // Fallback: if still 0, force-show everything and bail
      if (pastLen === 0) {
        pastPathEl.style.strokeDasharray = '';
        pastPathEl.style.strokeDashoffset = '';
        futurePathEl.style.strokeDasharray = '8 5';
        futurePathEl.style.strokeDashoffset = '0';
        markers.forEach(m => { m.style.opacity = '1'; });
        return;
      }

      pastPathEl.style.strokeDasharray  = String(pastLen);
      pastPathEl.style.strokeDashoffset = String(pastLen);
      futurePathEl.style.strokeDasharray  = String(futureLen);
      futurePathEl.style.strokeDashoffset = String(futureLen);

      const startTime = performance.now();

      function step(now) {
        const elapsed = now - startTime;

        const pastProg = easeOut(Math.min(1, elapsed / PAST_DURATION));
        pastPathEl.style.strokeDashoffset = String(pastLen * (1 - pastProg));

        const futureElapsed = Math.max(0, elapsed - FUTURE_DELAY);
        const futureProg = easeOut(Math.min(1, futureElapsed / FUTURE_DURATION));
        futurePathEl.style.strokeDashoffset = String(futureLen * (1 - futureProg));

        markers.forEach((marker) => {
          if (marker.style.opacity === '1') return;
          const age  = parseFloat(marker.dataset.age);
          const type = marker.dataset.type;
          let revealTime;
          if (type === 'future') {
            const prog = (age - present_age) / (55 - present_age);
            revealTime = FUTURE_DELAY + prog * FUTURE_DURATION * 0.9;
          } else {
            const prog = (age - 10) / (present_age - 10);
            revealTime = prog * PAST_DURATION * 0.9;
          }
          if (elapsed >= revealTime) {
            marker.style.transition = 'opacity 0.4s ease';
            marker.style.opacity = '1';
          }
        });

        if (elapsed < FUTURE_DELAY + FUTURE_DURATION + 400) {
          requestAnimationFrame(step);
        }
      }

      requestAnimationFrame(step);
    });
  }

  const io = new IntersectionObserver((entries) => {
    if (entries[0].isIntersecting) {
      io.disconnect();
      startAnimation();
    }
  }, { threshold: 0.1 });

  io.observe(section);
</script>
