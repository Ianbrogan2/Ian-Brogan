---
import type { SkillsData } from '../lib/content';
interface Props { data: SkillsData; }
const { data } = Astro.props;

const iconMap: Record<string, string> = {
  chart: `<path d="M3 3v18h18M7 16l4-4 4 4 4-8" stroke-linecap="round" stroke-linejoin="round"/>`,
  camera: `<path d="M23 19a2 2 0 01-2 2H3a2 2 0 01-2-2V8a2 2 0 012-2h4l2-3h6l2 3h4a2 2 0 012 2z"/><circle cx="12" cy="13" r="4"/>`,
  wrench: `<path d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z"/>`,
  flame: `<path d="M8.5 14.5A2.5 2.5 0 0011 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 11-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 002.5 2.5z"/>`,
};
---

<section id="skills" class="section" aria-labelledby="skills-heading">
  <div class="container">
    <div class="skills-grid">
      {data.categories.map((cat, ci) => (
        <div class="skill-category">
          <div class="skill-cat-header">
            <span class="skill-icon" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"
                set:html={iconMap[cat.icon] ?? ''}
              />
            </span>
            <h3>{cat.title}</h3>
          </div>
          <ul role="list" class="skill-list">
            {cat.items.map(item => (
              <li class={`skill-item skill-item--${item.level}`}>
                <button
                  type="button"
                  class="skill-btn"
                  data-name={item.name}
                  data-detail={item.detail ?? ''}
                  aria-label={`${item.name}: view details`}
                >
                  <span class="skill-dot" aria-label={`Level: ${item.level}`}></span>
                  <span>{item.name}</span>
                </button>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="skills-legend" role="note" aria-label="Skill level legend">
      <span class="legend-item">
        <span class="skill-dot skill-dot--core"></span>
        <span>Core</span>
      </span>
      <span class="legend-item">
        <span class="skill-dot skill-dot--advanced"></span>
        <span>Advanced</span>
      </span>
      <span class="legend-item">
        <span class="skill-dot skill-dot--learning"></span>
        <span>Building</span>
      </span>
    </div>
  </div>

  <div class="skill-modal-backdrop" id="skill-modal-backdrop" hidden>
    <div class="skill-modal" role="dialog" aria-modal="true" aria-labelledby="skill-modal-title">
      <button type="button" class="skill-modal-close" id="skill-modal-close" aria-label="Close">×</button>
      <h3 id="skill-modal-title"></h3>
      <p id="skill-modal-detail"></p>
    </div>
  </div>
</section>

<style>
  #skills { background: var(--color-bg); }

  .skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1.5rem;
    margin-bottom: 2rem;
  }

  .skill-category {
    background: var(--color-elevated);
    padding: 1.75rem;
    border: 1px solid var(--color-border);
    border-top: 3px solid var(--color-gold);
    transform-style: preserve-3d;
    transition: transform 0.15s ease, box-shadow 0.15s ease, border-color 0.2s;
    will-change: transform;
  }
  .skill-category:hover {
    box-shadow: 0 12px 40px rgba(0,0,0,0.4), 0 0 0 1px rgba(201,162,39,0.2);
  }

  .skill-cat-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
    padding-bottom: 1.25rem;
    border-bottom: 1px solid var(--color-border);
  }
  .skill-icon {
    color: var(--color-gold);
    flex-shrink: 0;
  }
  .skill-cat-header h3 {
    font-size: 0.85rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text);
    font-family: var(--font-body);
    font-weight: 600;
    margin: 0;
  }

  .skill-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
  }

  .skill-item {
    display: flex;
    align-items: center;
  }

  .skill-btn {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.875rem;
    color: var(--color-text-dim);
    background: none;
    border: none;
    padding: 0.6rem 0;
    min-height: 44px;
    margin: 0;
    font-family: inherit;
    cursor: pointer;
    text-align: left;
    transition: color 0.15s;
  }
  .skill-btn:hover, .skill-btn:focus-visible {
    color: var(--color-gold);
    outline: none;
  }

  .skill-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .skill-dot--core, .skill-item--core .skill-dot { background: var(--color-gold); }
  .skill-dot--advanced, .skill-item--advanced .skill-dot { background: var(--color-text-dim); }
  .skill-dot--learning, .skill-item--learning .skill-dot {
    background: transparent;
    border: 1.5px solid var(--color-muted);
  }

  .skill-item--learning .skill-btn { color: var(--color-muted); }
  .skill-item--learning span:last-child { font-style: italic; }

  .skill-modal-backdrop {
    position: fixed;
    inset: 0;
    background: rgba(8,8,9,0.75);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 100;
    padding: 1.5rem;
  }
  .skill-modal-backdrop[hidden] { display: none; }

  .skill-modal {
    position: relative;
    background: var(--color-elevated);
    border: 1px solid var(--color-border);
    border-top: 3px solid var(--color-gold);
    padding: 2rem;
    max-width: 480px;
    width: 100%;
    box-shadow: 0 20px 60px rgba(0,0,0,0.5);
  }

  .skill-modal h3 {
    font-family: var(--font-display);
    font-size: 1.25rem;
    color: var(--color-text);
    margin: 0 0 1rem;
    padding-right: 2rem;
  }

  .skill-modal p {
    font-size: 0.9rem;
    line-height: 1.7;
    color: var(--color-text-dim);
    margin: 0;
  }

  .skill-modal-close {
    position: absolute;
    top: 1rem;
    right: 1rem;
    background: none;
    border: none;
    color: var(--color-muted);
    font-size: 1.5rem;
    line-height: 1;
    cursor: pointer;
    padding: 0.25rem;
  }
  .skill-modal-close:hover { color: var(--color-gold); }

  .skills-legend {
    display: flex;
    gap: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-border);
  }
  .legend-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.75rem;
    letter-spacing: 0.04em;
    color: var(--color-muted);
  }
</style>

<script>
  // 3D tilt only on true hover+fine pointers (avoids stuck tilt on touch)
  if (window.matchMedia('(hover: hover) and (pointer: fine)').matches) {
    document.querySelectorAll<HTMLElement>('.skill-category').forEach(card => {
      card.addEventListener('mousemove', (e: MouseEvent) => {
        const r = card.getBoundingClientRect();
        const x = (e.clientX - r.left) / r.width  - 0.5;
        const y = (e.clientY - r.top)  / r.height - 0.5;
        card.style.transform = `perspective(600px) rotateX(${-y * 8}deg) rotateY(${x * 8}deg) translateZ(4px)`;
      });
      card.addEventListener('mouseleave', () => { card.style.transform = ''; });
    });
  }

  const backdrop = document.getElementById('skill-modal-backdrop') as HTMLElement;
  const titleEl = document.getElementById('skill-modal-title') as HTMLElement;
  const detailEl = document.getElementById('skill-modal-detail') as HTMLElement;
  const closeBtn = document.getElementById('skill-modal-close') as HTMLElement;

  let lastTrigger: HTMLElement | null = null;
  function openModal(name: string, detail: string, trigger: HTMLElement) {
    titleEl.textContent = name;
    detailEl.textContent = detail || 'Details coming soon.';
    backdrop.hidden = false;
    lastTrigger = trigger;
    closeBtn.focus();
  }
  function closeModal() {
    backdrop.hidden = true;
    lastTrigger?.focus();
  }

  document.querySelectorAll<HTMLElement>('.skill-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      openModal(btn.dataset.name ?? '', btn.dataset.detail ?? '', btn);
    });
  });

  closeBtn.addEventListener('click', closeModal);
  backdrop.addEventListener('click', (e) => {
    if (e.target === backdrop) closeModal();
  });
  document.addEventListener('keydown', (e) => {
    if (backdrop.hidden) return;
    if (e.key === 'Escape') closeModal();
    else if (e.key === 'Tab') { e.preventDefault(); closeBtn.focus(); } // trap focus (single control)
  });
</script>
