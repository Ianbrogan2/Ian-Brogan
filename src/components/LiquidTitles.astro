---
// LiquidTitles.astro · liquid-bead refraction for opted-in headings.
// The real <h*> text stays in the DOM; a transparent canvas overlay mirrors the
// browser's real glyph layout pixel-for-pixel (so wrapping/size/position/opsz
// match by construction) and refracts a small glass "bead" under the pointer or
// finger. Crisp at rest, heals on leave. Reduced-motion + no-JS safe.
---
<style is:global>
  [data-liquid] { position: relative; touch-action: pan-y; }
  [data-liquid] > canvas.liquid-canvas {
    position: absolute; inset: 0; width: 100%; height: 100%;
    pointer-events: none; z-index: 1;
  }
  /* !important so the canvas is the sole renderer while active, regardless of a
     heading's own (often scoped, equal-specificity) color rule. The class is
     only ever added in the same frame the canvas actually paints the text. */
  [data-liquid].liquid-on { color: transparent !important; }
  @media (prefers-reduced-motion: reduce) {
    [data-liquid].liquid-on { color: inherit !important; }
    [data-liquid] > canvas.liquid-canvas { display: none; }
  }
</style>

<script>
  (() => {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    const coarse = window.matchMedia('(pointer: coarse)').matches
                || !window.matchMedia('(hover: hover)').matches;
    const getDPR = () => Math.min(window.devicePixelRatio || 1, 2);

    // One shared set of window/document listeners drives every title.
    const instances: { heal: () => void; invalidate: () => void }[] = [];
    const healAll = () => { for (const t of instances) t.heal(); };
    const invalidateAll = () => { for (const t of instances) t.invalidate(); };
    let resizeT: number;
    window.addEventListener('resize', () => { clearTimeout(resizeT); resizeT = window.setTimeout(invalidateAll, 150); }, { passive: true });
    document.addEventListener('visibilitychange', () => { document.hidden ? healAll() : invalidateAll(); });
    const fonts = (document as any).fonts;
    if (fonts) {
      if (fonts.ready) fonts.ready.then(invalidateAll);
      if (fonts.addEventListener) fonts.addEventListener('loadingdone', invalidateAll);
    }

    function initTitle(el: HTMLElement) {
      if ((el as any).__liquidInit) return;
      const canvas = document.createElement('canvas');
      const ctx = canvas.getContext('2d');
      if (!ctx) return; // 2D context unavailable; leave the server-rendered text
      (el as any).__liquidInit = true;
      canvas.className = 'liquid-canvas';
      canvas.setAttribute('aria-hidden', 'true');
      el.appendChild(canvas);

      const isHero = el.id === 'hero-name';
      const money = isHero || el.hasAttribute('data-money');
      const STRENGTH = parseFloat(el.dataset.liquidStrength || '0.24');

      let dpr = getDPR();
      let W = 0, H = 0, off: HTMLCanvasElement | null = null, srcData: Uint8ClampedArray | null = null;
      let R = 30, sizeFactor = 1, rectNow: DOMRect | null = null;
      let scratch: ImageData | null = null, scratchSide = 0;

      // Build the offscreen source by MIRRORING the browser's real glyph layout:
      // walk text nodes, measure each glyph's on-screen rect, and draw it there
      // with its parent's resolved font. Wrapping/size/position/opsz all match by
      // construction, so hiding the DOM text and showing the canvas is seamless.
      function buildSource(): boolean {
        const elRect = el.getBoundingClientRect();
        if (elRect.width < 4 || elRect.height < 4) return false;
        // Don't capture mid-entrance-animation (hero rise / reveals) positions.
        if ((el as any).getAnimations && el.getAnimations({ subtree: true }).some((a: Animation) => a.playState === 'running')) return false;
        // Don't rasterize with a fallback font; rebuild once webfonts finish.
        if (fonts && fonts.status === 'loading') return false;

        dpr = getDPR();
        W = Math.round(elRect.width * dpr);
        H = Math.round(elRect.height * dpr);
        canvas.width = W; canvas.height = H;
        const offCanvas = document.createElement('canvas');
        offCanvas.width = W; offCanvas.height = H;
        const o = offCanvas.getContext('2d');
        if (!o) return false;
        o.clearRect(0, 0, W, H);
        o.textAlign = 'left';
        o.textBaseline = 'alphabetic';

        const rootFontPx = parseFloat(getComputedStyle(el).fontSize) * dpr;
        R = Math.max(18, Math.min(rootFontPx * 0.9, 130 * dpr));
        // The local zoom is scale-invariant, so a bead reads stronger on small
        // headings; ease it down for them (with a floor on touch).
        sizeFactor = Math.max(coarse ? 0.5 : 0, Math.min(1, rootFontPx / (64 * dpr)));

        const walker = document.createTreeWalker(el, NodeFilter.SHOW_TEXT);
        const range = document.createRange();
        let drew = false;
        let node: Node | null;
        while ((node = walker.nextNode())) {
          const text = node.nodeValue || '';
          if (!text.trim()) continue;
          const parent = node.parentElement;
          if (!parent) continue;
          const pcs = getComputedStyle(parent);
          if (pcs.visibility === 'hidden' || pcs.display === 'none') continue;

          o.fillStyle = pcs.color;
          o.font = `${pcs.fontStyle} ${pcs.fontWeight} ${parseFloat(pcs.fontSize) * dpr}px ${pcs.fontFamily}`;
          try { (o as any).fontVariationSettings = (pcs.fontVariationSettings && pcs.fontVariationSettings !== 'normal') ? pcs.fontVariationSettings : 'normal'; } catch (e) { /* opsz unsupported; positions still correct */ }
          try { (o as any).letterSpacing = (pcs.letterSpacing && pcs.letterSpacing !== 'normal') ? `${parseFloat(pcs.letterSpacing) * dpr}px` : '0px'; } catch (e) { /* letterSpacing unsupported */ }

          // Font metrics (per font) to place each glyph on its real CSS baseline.
          const fpx = parseFloat(pcs.fontSize) * dpr;
          const fm = o.measureText('Mg');
          const ascent = (fm.fontBoundingBoxAscent && !isNaN(fm.fontBoundingBoxAscent)) ? fm.fontBoundingBoxAscent : fpx * 0.8;
          const descent = (fm.fontBoundingBoxDescent && !isNaN(fm.fontBoundingBoxDescent)) ? fm.fontBoundingBoxDescent : fpx * 0.2;

          for (let i = 0; i < text.length; i++) {
            const ch = text[i];
            if (ch === ' ' || ch === '\n' || ch === '\t' || ch === '\r') continue;
            range.setStart(node, i);
            range.setEnd(node, i + 1);
            const gr = range.getBoundingClientRect();
            if (gr.width < 0.01 || gr.height < 0.01) continue;
            const gx = (gr.left - elRect.left) * dpr;
            // gr is the line box (height = line-height); CSS distributes the
            // leading evenly, so the baseline = lineTop + halfLeading + ascent.
            const lineTop = (gr.top - elRect.top) * dpr;
            const lineH = gr.height * dpr;
            const gy = lineTop + (lineH - (ascent + descent)) / 2 + ascent;
            o.fillText(ch, gx, gy);
            drew = true;
          }
        }
        if (!drew) return false; // nothing measurable; never hide the real text

        srcData = o.getImageData(0, 0, W, H).data;
        off = offCanvas;
        const side = Math.ceil(2 * R) + 2;
        if (!scratch || side > scratchSide) { scratch = ctx!.createImageData(side, side); scratchSide = side; }
        return true;
      }

      const bead = { x: -9999, y: -9999, tx: -9999, ty: -9999, on: false, pulse: 0 };
      let raf: number | null = null, lastMoney = 0;

      function point(e: PointerEvent) {
        rectNow = el.getBoundingClientRect();
        bead.tx = (e.clientX - rectNow.left) * dpr;
        bead.ty = (e.clientY - rectNow.top) * dpr;
      }
      function ensureSource(): boolean { return srcData ? true : buildSource(); }
      // Snap back to crisp resting text immediately (tab-hide / any failure).
      function heal() {
        bead.on = false; bead.pulse = 0;
        bead.x = bead.y = bead.tx = bead.ty = -9999;
        if (raf != null) { if (raf > 0) cancelAnimationFrame(raf); raf = null; }
        el.classList.remove('liquid-on');
        try { if (W && H) ctx!.clearRect(0, 0, W, H); } catch (e) { /* context gone */ }
      }
      function start() { if (raf == null) { raf = -1; frame(); } }

      function refract(cx: number, cy: number, r: number, strength: number) {
        cx = Math.round(cx); cy = Math.round(cy);
        const x0 = Math.max(0, Math.floor(cx - r)), x1 = Math.min(W, Math.ceil(cx + r));
        const y0 = Math.max(0, Math.floor(cy - r)), y1 = Math.min(H, Math.ceil(cy + r));
        const rw = x1 - x0, rh = y1 - y0;
        if (rw <= 0 || rh <= 0 || !srcData || !scratch) return;
        const od = scratch.data, stride = scratchSide;
        for (let j = 0; j < rh; j++) {
          const py = y0 + j;
          for (let i = 0; i < rw; i++) {
            const px = x0 + i;
            let sx = px, sy = py;
            const dx = px - cx, dy = py - cy;
            const d = Math.sqrt(dx * dx + dy * dy);
            if (d < r) {
              const f = 1 - d / r; const m = f * f * strength * 1.8;
              sx = Math.round(px - dx * m); sy = Math.round(py - dy * m);
              if (sx < 0) sx = 0; else if (sx >= W) sx = W - 1;
              if (sy < 0) sy = 0; else if (sy >= H) sy = H - 1;
            }
            const si = (sy * W + sx) * 4, di = (j * stride + i) * 4;
            od[di] = srcData[si]; od[di + 1] = srcData[si + 1];
            od[di + 2] = srcData[si + 2]; od[di + 3] = srcData[si + 3];
          }
        }
        ctx!.putImageData(scratch, x0, y0, 0, 0, rw, rh);
      }

      function frame() {
        try {
          if (!srcData && !buildSource()) { bead.on = false; bead.pulse = 0; raf = null; el.classList.remove('liquid-on'); return; }
          if (bead.x < -9000) { bead.x = bead.tx; bead.y = bead.ty; }
          bead.x += (bead.tx - bead.x) * 0.35;
          bead.y += (bead.ty - bead.y) * 0.35;
          const strength = STRENGTH * sizeFactor * (bead.on ? 1 : bead.pulse);
          if (strength > 0.002 && bead.x > -9000) {
            // Visible bead: paint the full (pixel-matched) text + refraction, and
            // only NOW hide the DOM text. So the real text is never hidden
            // without the canvas already rendering it in the same frame.
            ctx!.clearRect(0, 0, W, H);
            ctx!.drawImage(off!, 0, 0);
            refract(bead.x, bead.y, R, strength);
            el.classList.add('liquid-on');
            if (money && (window as any).fxMoney && rectNow) {
              const now = performance.now();
              if (now - lastMoney > 90) {
                (window as any).fxMoney(rectNow.left + bead.x / dpr, rectNow.top + bead.y / dpr, 1, 10);
                lastMoney = now;
              }
            }
          } else {
            // No visible bead: clear the canvas and show the real DOM text.
            ctx!.clearRect(0, 0, W, H);
            el.classList.remove('liquid-on');
          }
          if (!bead.on) bead.pulse *= coarse ? 0.965 : 0.92;
          const settled = !bead.on && bead.pulse < 0.02 && Math.abs(bead.tx - bead.x) < 0.5;
          if (settled) raf = null;
          else raf = requestAnimationFrame(frame);
        } catch (err) {
          // Any canvas failure: fall back to the real, colored DOM text.
          el.classList.remove('liquid-on');
          try { if (W && H) ctx!.clearRect(0, 0, W, H); } catch (e) { /* context gone */ }
          srcData = null; off = null; bead.on = false; bead.pulse = 0; raf = null;
        }
      }

      // Mouse hover sustains the bead; touch drives it from down..up so a finger
      // drag gets the same moving bead, and a tap gets a decaying pulse.
      el.addEventListener('pointerenter', (e) => { if (coarse) return; if (!ensureSource()) return; point(e); bead.on = true; start(); });
      el.addEventListener('pointermove', (e) => { point(e); if (bead.on) start(); }, { passive: true });
      el.addEventListener('pointerleave', () => { bead.on = false; start(); });
      el.addEventListener('pointerdown', (e) => { if (!ensureSource()) return; point(e); bead.on = true; bead.x = bead.tx; bead.y = bead.ty; bead.pulse = 1; start(); });
      el.addEventListener('pointerup', () => { bead.on = false; bead.pulse = Math.max(bead.pulse, 0.85); start(); });
      // Soft cancel (e.g. a scroll gesture takes over): let the pulse fade out
      // rather than hard-clearing, so the title never blinks.
      el.addEventListener('pointercancel', () => { bead.on = false; start(); });

      instances.push({ heal, invalidate: () => { srcData = null; off = null; if (raf == null) el.classList.remove('liquid-on'); } });
    }

    // Init every opted-in title up front. This only creates an empty,
    // transparent canvas + listeners (cheap); the expensive source render and
    // rAF loop stay deferred until the first pointer/touch interaction.
    function boot() {
      document.querySelectorAll<HTMLElement>('[data-liquid], #hero-name').forEach((t) => initTitle(t));
    }
    if (document.readyState !== 'loading') boot();
    else document.addEventListener('DOMContentLoaded', boot);
  })();
</script>
