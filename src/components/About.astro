---
import type { AboutData } from '../lib/content';
import Placeholder from './Placeholder.astro';
interface Props { data: AboutData; }
const { data } = Astro.props;
---

<section id="about" class="section" aria-labelledby="about-heading">
  <div class="container">
    <div class="about-grid">
      <div class="about-image-col">
        <div class="about-img-wrap reveal">
          <Placeholder
            caption={data.image_alt}
            aspectRatio="3/4"
          />
          <!-- Offset accent block -->
          <div class="about-img-offset" aria-hidden="true"></div>
        </div>

        <!-- Quote callout — breaks the grid line intentionally -->
        <blockquote class="duality-pull reveal reveal-delay-2">
          <p>"{data.duality_quote}"</p>
        </blockquote>
      </div>

      <div class="about-text-col">
        <span class="eyebrow reveal">About</span>
        <span class="rule-gold reveal reveal-delay-1"></span>
        <h2 id="about-heading" class="reveal reveal-delay-1">{data.headline}</h2>
        <p class="lead reveal reveal-delay-2">{data.subhead}</p>

        <div class="about-body">
          {data.body.map((para, i) => (
            <p class={`reveal reveal-delay-${Math.min(i + 2, 4)}`}>{para}</p>
          ))}
        </div>

        <!-- Facts row -->
        <ul class="facts-row reveal reveal-delay-3" role="list">
          {data.facts.map(fact => (
            <li class="fact">
              <span class="fact-value">{fact.value}</span>
              <span class="fact-label">{fact.label}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>

<style>
  #about { background: var(--color-bone); }

  .about-grid {
    display: grid;
    grid-template-columns: 5fr 7fr;
    gap: clamp(3rem, 6vw, 7rem);
    align-items: start;
  }

  /* Image column */
  .about-image-col { position: relative; }

  .about-img-wrap { position: relative; z-index: 1; }
  .about-img-offset {
    position: absolute;
    top: 1.5rem;
    left: -1.5rem;
    width: 100%;
    height: 100%;
    border: 2px solid var(--color-bone-dk);
    z-index: -1;
  }

  .duality-pull {
    margin: 2.5rem 0 0;
    padding-left: 1.5rem;
    border-left: 3px solid var(--color-gold);
  }
  .duality-pull p {
    font-family: var(--font-display);
    font-size: clamp(1.1rem, 2vw, 1.4rem);
    font-variation-settings: 'opsz' 36;
    font-style: italic;
    color: var(--color-oxblood);
    line-height: 1.4;
    max-width: none;
    margin: 0;
  }

  /* Text column */
  .about-text-col { padding-top: 1rem; }

  h2 {
    margin: 0 0 1.25rem;
    color: var(--color-oxblood-dk);
  }

  .lead { margin-bottom: 2rem; }

  .about-body p { color: rgba(22, 19, 17, 0.82); }

  /* Facts row */
  .facts-row {
    display: flex;
    gap: 2rem;
    flex-wrap: wrap;
    list-style: none;
    padding: 0;
    margin: 2.5rem 0 0;
    border-top: 1px solid var(--color-bone-dk);
    padding-top: 2rem;
  }

  .fact {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .fact-value {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 700;
    font-variation-settings: 'opsz' 24;
    color: var(--color-oxblood);
    letter-spacing: -0.02em;
  }
  .fact-label {
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-mist);
  }

  @media (max-width: 900px) {
    .about-grid {
      grid-template-columns: 1fr;
    }
    .about-image-col { max-width: 360px; }
    .about-img-offset { display: none; }
  }
</style>
