---
import type { InvestingData } from '../lib/content';
interface Props { data: InvestingData; }
const { data } = Astro.props;
---

<section id="investing" class="section section--alt" aria-labelledby="investing-heading">
  <div class="container">
    <div class="investing-layout">
      <div class="investing-text reveal">
        <span class="eyebrow">Investing</span>
        <span class="rule-gold"></span>
        <h2 id="investing-heading">{data.headline}</h2>
        <p class="lead">{data.subhead}</p>

        <div class="investing-body">
          {data.body.map((para, i) => (
            <p class={`reveal reveal-delay-${i + 1}`}>{para}</p>
          ))}
        </div>

        <p class="career-note reveal reveal-delay-3">{data.career_note}</p>
      </div>

      <aside class="investing-philosophy reveal reveal-delay-2" aria-label="Investment philosophy">
        <h3>Philosophy</h3>
        <ul role="list">
          {data.philosophy.map(item => (
            <li>
              <span class="phil-dash" aria-hidden="true">—</span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </aside>
    </div>
  </div>
</section>

<style>
  #investing { background: var(--color-bone-dk); position: relative; overflow: hidden; }

  /* Background texture: faint market-grid lines */
  #investing::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(22,19,17,0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(22,19,17,0.03) 1px, transparent 1px);
    background-size: 60px 60px;
    pointer-events: none;
  }

  .investing-layout {
    position: relative;
    display: grid;
    grid-template-columns: 3fr 2fr;
    gap: clamp(3rem, 6vw, 7rem);
    align-items: start;
  }

  h2 { margin-bottom: 1.25rem; }
  .lead { margin-bottom: 2rem; }

  .investing-body p { color: rgba(22,19,17,0.8); }

  .career-note {
    margin-top: 2rem;
    padding: 1.25rem 1.5rem;
    border-left: 3px solid var(--color-oxblood);
    background: rgba(107, 31, 42, 0.05);
    font-size: 0.9rem;
    color: var(--color-oxblood-dk);
    font-style: italic;
    max-width: 55ch;
  }

  /* Philosophy sidebar */
  .investing-philosophy {
    padding: 2rem;
    background: var(--color-bone);
    border: 1px solid rgba(22,19,17,0.08);
    box-shadow: 0 4px 24px rgba(22,19,17,0.06);
  }
  .investing-philosophy h3 {
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-gold);
    margin: 0 0 1.25rem;
    font-family: var(--font-body);
    font-weight: 600;
  }
  .investing-philosophy ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .investing-philosophy li {
    display: flex;
    gap: 0.75rem;
    font-size: 0.875rem;
    line-height: 1.55;
    color: rgba(22,19,17,0.82);
    border-bottom: 1px solid var(--color-bone-dk);
    padding-bottom: 1rem;
  }
  .investing-philosophy li:last-child { border: none; padding: 0; }
  .phil-dash {
    color: var(--color-gold);
    font-weight: 700;
    flex-shrink: 0;
    font-family: var(--font-display);
  }

  @media (max-width: 900px) {
    .investing-layout { grid-template-columns: 1fr; }
    .investing-philosophy { order: -1; }
  }
</style>
