---
import type { InvestingData } from '../lib/content';
interface Props { data: InvestingData; }
const { data } = Astro.props;
---

<section id="investing" class="section" aria-labelledby="investing-heading">
  <div class="container">
    <div class="investing-layout">
      <div class="investing-text">
        <h2 id="investing-heading">{data.headline}</h2>
        <p class="lead">{data.subhead}</p>

        <div class="investing-body">
          {data.body.map((para) => (
            <p>{para}</p>
          ))}
        </div>

        <p class="career-note">{data.career_note}</p>
      </div>

      <aside class="investing-holdings" aria-label="Current holdings">
        <h3>Holdings</h3>
        <ul role="list" class="holdings-grid">
          {data.holdings.map(h => (
            <li class="holding">
              <button
                type="button"
                class="holding-symbol"
                data-href={`https://finance.yahoo.com/quote/${h.symbol}/`}
              >
                {h.symbol}
              </button>
              <div class="holding-tooltip" role="tooltip">{h.blurb}</div>
            </li>
          ))}
        </ul>
      </aside>
    </div>
  </div>
</section>

<style>
  #investing { background: var(--color-surface); position: relative; overflow: hidden; }

  #investing::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(237,232,223,0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(237,232,223,0.03) 1px, transparent 1px);
    background-size: 60px 60px;
    pointer-events: none;
  }

  .investing-layout {
    position: relative;
    display: grid;
    grid-template-columns: 3fr 2fr;
    gap: clamp(3rem, 6vw, 7rem);
    align-items: start;
  }

  h2 { margin-bottom: 1.25rem; color: var(--color-text); }
  .lead { margin-bottom: 2rem; color: var(--color-text-dim); }

  .investing-body p {
    color: var(--color-text-dim);
    line-height: 1.75;
    margin-bottom: 1em;
  }

  .career-note {
    margin-top: 2rem;
    padding: 1.25rem 1.5rem;
    border-left: 3px solid var(--color-gold);
    background: rgba(201, 162, 39, 0.06);
    font-size: 0.9rem;
    color: var(--color-text-dim);
    font-style: italic;
    max-width: 55ch;
  }

  .investing-holdings {
    padding: 2rem;
    background: var(--color-elevated);
    border: 1px solid var(--color-border);
    position: sticky;
    top: 6rem;
  }
  .investing-holdings h3 {
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-gold);
    margin: 0 0 1.25rem;
    font-family: var(--font-body);
    font-weight: 600;
  }

  .holdings-grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(72px, 1fr));
    gap: 0.6rem;
  }

  .holding {
    position: relative;
  }

  .holding-symbol {
    display: block;
    text-align: center;
    padding: 0.5rem 0.4rem;
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    color: var(--color-text);
    font-family: var(--font-display);
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-decoration: none;
    cursor: pointer;
    width: 100%;
    transition: border-color 0.15s, color 0.15s;
  }
  .holding-symbol:hover, .holding-symbol:focus-visible {
    border-color: var(--color-gold);
    color: var(--color-gold);
  }

  .holdings-grid { overflow: visible; }

  .holding-tooltip {
    position: absolute;
    left: 50%;
    bottom: calc(100% + 0.6rem);
    transform: translateX(-50%) translateY(6px);
    width: max(240px, 160%);
    max-width: 320px;
    background: var(--color-bg);
    border: 1px solid var(--color-gold);
    padding: 0.9rem 1rem;
    font-size: 0.78rem;
    line-height: 1.6;
    color: var(--color-text-dim);
    z-index: 50;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity 0.15s, transform 0.15s;
    box-shadow: 0 12px 30px rgba(0,0,0,0.5);
  }
  .holding.active .holding-tooltip,
  .holding:hover .holding-tooltip,
  .holding:focus-within .holding-tooltip {
    opacity: 1;
    visibility: visible;
    transform: translateX(-50%) translateY(0);
  }

  @media (max-width: 900px) {
    .investing-layout { grid-template-columns: 1fr; }
    .investing-holdings { order: -1; position: static; }
  }

  @media (max-width: 600px) {
    .holding-tooltip {
      position: fixed;
      left: 1rem;
      right: 1rem;
      bottom: auto;
      top: 50%;
      width: auto;
      max-width: none;
      transform: translateY(-50%) scale(0.97);
    }
    .holding.active .holding-tooltip,
    .holding:hover .holding-tooltip,
    .holding:focus-within .holding-tooltip {
      transform: translateY(-50%) scale(1);
    }
  }
</style>

<script>
  document.querySelectorAll<HTMLButtonElement>('.holding-symbol').forEach(btn => {
    btn.addEventListener('click', () => {
      const holding = btn.closest('.holding');
      const wasActive = holding?.classList.contains('active');
      document.querySelectorAll('.holding.active').forEach(h => h.classList.remove('active'));
      if (!wasActive) holding?.classList.add('active');
    });
    btn.addEventListener('dblclick', () => {
      const url = btn.dataset.href;
      if (url) window.open(url, '_blank', 'noopener,noreferrer');
    });
  });

  document.addEventListener('click', (e) => {
    if (!(e.target as HTMLElement).closest('.holding')) {
      document.querySelectorAll('.holding.active').forEach(h => h.classList.remove('active'));
    }
  });
</script>
