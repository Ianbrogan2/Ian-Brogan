---
// Money effects. Clicking a capital/investing button (anything [data-money]
// or a content link to /investing) makes gold dollar signs flow off it.
// Also exposes window.fxMoney(x,y,count,spread) so the logo jello-slice can
// stream coins around the cursor while you cut. Transform/opacity only,
// reduced-motion safe, holds navigation briefly so the effect is seen.
---
<style is:global>
  /* Global (not scoped) so the JS-created dollar signs pick up these styles. */
  .fx-layer {
    position: fixed;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
    z-index: 10000;
  }
  .fx-money {
    position: absolute;
    transform: translate(-50%, -50%);
    color: var(--color-gold);
    font-family: var(--font-display);
    font-weight: 700;
    font-variation-settings: 'opsz' 40;
    text-shadow: 0 0 14px rgba(201, 162, 39, 0.6);
    will-change: transform, opacity;
    user-select: none;
    opacity: 0;
  }
  @media (prefers-reduced-motion: reduce) {
    .fx-money { display: none; }
  }
</style>

<script>
  function setupMoneyFx() {
    if ((document.body as any).__moneyFxBound) return;
    (document.body as any).__moneyFxBound = true;

    const reduce = () => window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    let layer: HTMLElement | null = null;
    function getLayer() {
      if (!layer || !layer.isConnected) {
        layer = document.createElement('div');
        layer.className = 'fx-layer';
        document.body.appendChild(layer);
      }
      return layer;
    }

    // Spawn `count` gold dollar signs at (x,y) that flow up and off. Reused by
    // the button effect (spread across the button) and the logo-slice (cursor).
    function fxMoney(x: number, y: number, count: number, spreadX = 20) {
      if (reduce()) return;
      const L = getLayer();
      for (let i = 0; i < count; i++) {
        const s = document.createElement('span');
        s.className = 'fx-money';
        s.textContent = '$';
        s.style.left = (x + (Math.random() - 0.5) * spreadX) + 'px';
        s.style.top = (y + (Math.random() - 0.5) * 16) + 'px';
        s.style.fontSize = (0.8 + Math.random() * 1.5) + 'rem';
        const dx = (Math.random() - 0.5) * 130;
        const dy = -(110 + Math.random() * 270);  // flow up/off
        const rot = (Math.random() - 0.5) * 150;
        const dur = 800 + Math.random() * 650;
        L.appendChild(s);
        const anim = s.animate(
          [
            { transform: 'translate(-50%, -50%) translate(0px, 0px) rotate(0deg)', opacity: 0 },
            { offset: 0.15, opacity: 0.95 },
            { offset: 0.8, opacity: 0.95 },
            { transform: `translate(-50%, -50%) translate(${dx}px, ${dy}px) rotate(${rot}deg)`, opacity: 0 },
          ],
          { duration: dur, easing: 'cubic-bezier(0.22, 1, 0.36, 1)', fill: 'forwards' }
        );
        anim.onfinish = () => s.remove();
      }
    }
    (window as any).fxMoney = fxMoney;

    let navigating = false;
    document.addEventListener('click', (e) => {
      const el = (e.target as HTMLElement).closest('[data-money], a[href^="/investing"]:not(.nav-link)') as HTMLElement | null;
      if (!el) return;
      if (reduce()) return;

      const href = el.getAttribute('href');
      const isAnchorNav = el.tagName === 'A' && !!href && !href.startsWith('#') && (el as HTMLAnchorElement).target !== '_blank';
      // ignore rapid repeat clicks while a hold is pending (no double burst, no nav race)
      if (navigating) { if (isAnchorNav) e.preventDefault(); return; }

      const r = el.getBoundingClientRect();
      // flow off the button: spawn across its width, biased to its upper area
      fxMoney(r.left + r.width / 2, r.top + r.height * 0.35, 26, Math.max(40, r.width * 0.9));

      if (isAnchorNav) {
        navigating = true;
        e.preventDefault();
        setTimeout(() => { window.location.href = href!; }, 800);
      }
    });
  }

  setupMoneyFx();
  document.addEventListener('astro:page-load', setupMoneyFx);
</script>
