---
import type { AchievementsData } from '../lib/content';
interface Props { data: AchievementsData; }
const { data } = Astro.props;
const courseGroups = [
  { label: 'AP', items: data.coursework.ap },
  { label: 'Honors', items: data.coursework.honors },
  { label: 'CTE', items: data.coursework.cte },
];
---

<section id="achievements" class="section" aria-label="School achievements" data-am-section>
  <div class="container">

    <!-- Stat strip -->
    <ul role="list" class="stats-grid" id="stats" data-am-section>
      {data.stats.map((s, i) => {
        const isSeal = i === data.stats.length - 1;
        return (
          <li class="stat">
            {isSeal ? (
              <button type="button" class="stat-seal-btn" id="seal-open" aria-haspopup="dialog" aria-expanded="false">
                <span class="stat-value">{s.value}</span>
                <span class="stat-label">{s.label}</span>
                {s.sublabel && <span class="stat-sublabel stat-sublabel--link">{s.sublabel}</span>}
              </button>
            ) : (
              <>
                <span class="stat-value">{s.value}</span>
                <span class="stat-label">{s.label}</span>
                {s.sublabel && <span class="stat-sublabel">{s.sublabel}</span>}
              </>
            )}
          </li>
        );
      })}
    </ul>

    <div class="achievements-layout">
      <!-- Leadership timeline -->
      <div class="leadership" id="leadership" data-am-section>
        <h3 class="section-title">Leadership & activities</h3>
        <ol role="list" class="timeline">
          {data.leadership.map((entry, i) => {
            const defaultOpen = !!entry.beforeAfter;
            return (
              <li class={`am-case${defaultOpen ? ' open' : ''}`}>
                <div class="am-case-head">
                  <div class="am-case-marker" aria-hidden="true"><span class="am-dot"></span></div>
                  <div class="am-case-titles">
                    <span class="am-case-grade">{entry.grade} · {entry.years}</span>
                    <strong class="am-case-role">{entry.role}</strong>
                    <span class="am-case-org">{entry.org}</span>
                    <p class="am-case-desc">{entry.description}</p>
                  </div>
                  <button
                    type="button"
                    class="am-case-toggle"
                    aria-expanded={defaultOpen ? 'true' : 'false'}
                  >
                    <span class="am-toggle-label">{defaultOpen ? 'Case study' : 'View case study'}</span>
                    <span class="am-toggle-icon" aria-hidden="true"></span>
                  </button>
                </div>

                <div class="am-case-panel" hidden={!defaultOpen}>
                  <div class="am-beat">
                    <span class="am-beat-label">Responsibility</span>
                    <p>{entry.responsibility}</p>
                  </div>
                  <div class="am-beat">
                    <span class="am-beat-label">Decision &amp; action</span>
                    <p>{entry.decision}</p>
                  </div>
                  <div class="am-beat">
                    <span class="am-beat-label">Result</span>
                    <p>{entry.result}</p>
                  </div>

                  {entry.beforeAfter && (
                    <div class="am-beforeafter">
                      <div class="am-ba-col am-ba-before">
                        <span class="am-ba-tag">Before</span>
                        <p>{entry.beforeAfter.before}</p>
                      </div>
                      <div class="am-ba-col am-ba-after">
                        <span class="am-ba-tag">After</span>
                        <p>{entry.beforeAfter.after}</p>
                      </div>
                    </div>
                  )}

                  {entry.whyItMattered && (
                    <p class="am-why">{entry.whyItMattered}</p>
                  )}
                </div>
              </li>
            );
          })}
        </ol>
      </div>

      <!-- Side column: coursework + biliteracy + service -->
      <div class="side-column">
        <div class="coursework" id="coursework" data-am-section>
          <h3 class="section-title">Coursework</h3>
          {courseGroups.map((g) => (
            <div class="course-group">
              <span class="course-group-label">{g.label} <span class="course-count">{g.items.length}</span></span>
              <ul role="list" class="course-list">
                {g.items.map((c) => <li>{c}</li>)}
              </ul>
              {g.label === 'CTE' && (
                <span class="course-pathway">California Arts, Media &amp; Entertainment (AME) pathway</span>
              )}
            </div>
          ))}
        </div>

        <div class="biliteracy">
          <h3 class="section-title">Bilingual &amp; biliterate</h3>
          <p>{data.biliteracy}</p>
        </div>

        <div class="service" id="service" data-am-section>
          <h3 class="section-title">{data.service.headline}</h3>
          <ul role="list" class="service-list">
            {data.service.items.map((item) => (
              <li class="service-item">
                <span class="service-hours">{item.hours}</span>
                <div class="service-detail">
                  <strong>{item.role}</strong>
                  <p>{item.description}</p>
                </div>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>

    <div class="achievements-closing">
      <p class="closing-text">"{data.closing}"</p>
    </div>
  </div>

  <!-- Golden State Seal modal -->
  <div class="seal-backdrop" id="seal-backdrop" hidden>
    <div class="seal-modal" role="dialog" aria-modal="true" aria-labelledby="seal-modal-title">
      <button type="button" class="seal-close" id="seal-close" aria-label="Close">&times;</button>
      <h4 id="seal-modal-title">Golden State Seal Merit Diploma</h4>
      <p>{data.sealCriteria}</p>
    </div>
  </div>
</section>

<style>
  #achievements { background: var(--color-elevated); position: relative; overflow: hidden; }
  #achievements::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(237,232,223,0.025) 1px, transparent 1px),
      linear-gradient(90deg, rgba(237,232,223,0.025) 1px, transparent 1px);
    background-size: 80px 80px;
    pointer-events: none;
  }

  .section-title {
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-gold);
    font-family: var(--font-body);
    font-weight: 600;
    margin: 0 0 1.5rem;
  }

  /* Stats */
  .stats-grid {
    list-style: none;
    margin: 0 0 clamp(3rem, 6vw, 5rem);
    padding: 0;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: var(--color-border);
    border: 1px solid var(--color-border);
  }
  .stat { background: var(--color-bg); }
  .stat, .stat-seal-btn {
    padding: clamp(1.5rem, 3vw, 2.25rem) clamp(1rem, 2vw, 1.5rem);
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    text-align: left;
    width: 100%;
  }
  .stat-seal-btn {
    background: var(--color-bg);
    border: none;
    cursor: pointer;
    font: inherit;
    color: inherit;
    transition: background 0.2s;
  }
  .stat-seal-btn:hover, .stat-seal-btn:focus-visible { background: rgba(201,162,39,0.07); }
  .stat-value {
    font-family: var(--font-display);
    font-size: clamp(1.4rem, 3.4vw, 2.3rem);
    font-variation-settings: 'opsz' 48;
    font-weight: 700;
    color: var(--color-gold);
    line-height: 1.05;
  }
  .stat-label { font-size: 0.78rem; color: var(--color-text); font-weight: 600; }
  .stat-sublabel { font-size: 0.72rem; color: var(--color-muted); }
  .stat-sublabel--link { color: var(--color-gold); text-decoration: underline; text-underline-offset: 3px; }

  /* Layout */
  .achievements-layout {
    display: grid;
    grid-template-columns: 7fr 5fr;
    gap: clamp(3rem, 6vw, 7rem);
    margin-bottom: clamp(3rem, 5vw, 5rem);
  }

  /* Timeline / case studies */
  .timeline { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 1.25rem; }
  .am-case {
    border: 1px solid var(--color-border);
    background: var(--color-bg);
  }
  .am-case.open { border-color: rgba(201,162,39,0.4); }
  .am-case-head {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 1rem;
    padding: 1.25rem 1.5rem;
    align-items: start;
  }
  .am-case-marker { padding-top: 0.4rem; }
  .am-dot { display: block; width: 9px; height: 9px; border-radius: 50%; background: var(--color-gold); }
  .am-case-titles { display: flex; flex-direction: column; gap: 0.2rem; min-width: 0; }
  .am-case-grade { font-size: 0.66rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--color-gold); }
  .am-case-role {
    font-family: var(--font-display);
    font-size: 1.15rem;
    font-variation-settings: 'opsz' 18;
    font-weight: 700;
    color: var(--color-text);
  }
  .am-case-org { font-size: 0.8rem; color: var(--color-text-dim); font-style: italic; }
  .am-case-desc { font-size: 0.85rem; color: var(--color-text-dim); line-height: 1.5; margin: 0.35rem 0 0; }

  .am-case-toggle {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: none;
    border: 1px solid var(--color-border);
    color: var(--color-text-dim);
    font-family: var(--font-body);
    font-size: 0.66rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-weight: 600;
    padding: 0.5rem 0.75rem;
    cursor: pointer;
    white-space: nowrap;
    transition: color 0.2s, border-color 0.2s;
    min-height: 44px;
  }
  .am-case-toggle:hover, .am-case-toggle:focus-visible { color: var(--color-gold); border-color: var(--color-gold); }
  .am-toggle-icon {
    width: 8px; height: 8px;
    border-right: 1.5px solid currentColor;
    border-bottom: 1.5px solid currentColor;
    transform: rotate(45deg);
    transition: transform 0.25s var(--ease-expo, ease);
  }
  .am-case.open .am-toggle-icon { transform: rotate(-135deg); }

  .am-case-panel {
    padding: 0 1.5rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    border-top: 1px solid var(--color-border);
    margin-top: -0.25rem;
    padding-top: 1.25rem;
  }
  .am-beat { display: flex; flex-direction: column; gap: 0.3rem; }
  .am-beat-label {
    font-size: 0.62rem; letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--color-gold); font-weight: 700;
  }
  .am-beat p { font-size: 0.85rem; color: var(--color-text-dim); line-height: 1.6; margin: 0; }

  .am-beforeafter { display: grid; grid-template-columns: 1fr 1fr; gap: 1px; background: var(--color-border); border: 1px solid var(--color-border); }
  .am-ba-col { background: var(--color-surface); padding: 1rem; display: flex; flex-direction: column; gap: 0.4rem; }
  .am-ba-tag { font-size: 0.6rem; letter-spacing: 0.14em; text-transform: uppercase; font-weight: 700; }
  .am-ba-before .am-ba-tag { color: var(--color-muted); }
  .am-ba-after .am-ba-tag { color: var(--color-gold); }
  .am-ba-col p { font-size: 0.8rem; color: var(--color-text-dim); line-height: 1.55; margin: 0; }

  .am-why {
    font-style: italic;
    color: var(--color-text-dim);
    font-size: 0.86rem;
    line-height: 1.6;
    border-left: 3px solid var(--color-gold);
    padding-left: 1rem;
    margin: 0;
  }

  /* Side column */
  .side-column { display: flex; flex-direction: column; gap: clamp(2.5rem, 4vw, 3.5rem); }

  .course-group { margin-bottom: 1.25rem; }
  .course-group:last-child { margin-bottom: 0; }
  .course-group-label {
    display: flex; align-items: center; gap: 0.5rem;
    font-size: 0.68rem; letter-spacing: 0.12em; text-transform: uppercase;
    color: var(--color-text); font-weight: 600; margin-bottom: 0.5rem;
  }
  .course-count {
    display: inline-flex; align-items: center; justify-content: center;
    min-width: 1.4rem; height: 1.4rem; padding: 0 0.35rem;
    background: rgba(201,162,39,0.12);
    border: 1px solid rgba(201,162,39,0.4);
    color: var(--color-gold);
    font-size: 0.7rem; font-weight: 700;
  }
  .course-list { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.3rem; }
  .course-list li { font-size: 0.8rem; color: var(--color-text-dim); line-height: 1.5; padding-left: 1rem; position: relative; }
  .course-list li::before { content: ''; position: absolute; left: 0; top: 0.6em; width: 5px; height: 1px; background: var(--color-gold); }
  .course-pathway { display: block; margin-top: 0.6rem; font-size: 0.72rem; color: var(--color-muted); font-style: italic; }

  .biliteracy p { font-size: 0.85rem; color: var(--color-text-dim); line-height: 1.65; margin: 0; }

  .service-list { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 1.25rem; }
  .service-item { display: flex; gap: 1rem; align-items: flex-start; }
  .service-hours { flex-shrink: 0; font-family: var(--font-display); font-size: 1rem; font-weight: 700; color: var(--color-gold); min-width: 5.5rem; }
  .service-detail strong { display: block; font-size: 0.875rem; color: var(--color-text); margin-bottom: 0.25rem; }
  .service-detail p { font-size: 0.8rem; color: var(--color-text-dim); line-height: 1.55; margin: 0; }

  /* Closing */
  .achievements-closing { position: relative; padding: 2.5rem 0 0; border-top: 1px solid var(--color-border); }
  .closing-text {
    font-family: var(--font-display);
    font-size: clamp(1.1rem, 2vw, 1.5rem);
    font-variation-settings: 'opsz' 36;
    font-style: italic;
    color: var(--color-text-dim);
    line-height: 1.45;
    max-width: 70ch;
    margin: 0;
  }

  /* Seal modal */
  .seal-backdrop {
    position: fixed; inset: 0; z-index: 300;
    background: rgba(8,8,9,0.75);
    backdrop-filter: blur(4px);
    display: flex; align-items: center; justify-content: center;
    padding: 1.5rem;
  }
  .seal-backdrop[hidden] { display: none; }
  .seal-modal {
    position: relative;
    max-width: 440px;
    background: var(--color-bg);
    border: 1px solid var(--color-gold);
    padding: 2rem;
    box-shadow: 0 20px 50px rgba(0,0,0,0.6);
  }
  .seal-modal h4 {
    font-family: var(--font-display);
    color: var(--color-gold);
    font-size: 1.2rem;
    margin: 0 0 0.75rem;
  }
  .seal-modal p { font-size: 0.9rem; color: var(--color-text-dim); line-height: 1.65; margin: 0; }
  .seal-close {
    position: absolute; top: 0.5rem; right: 0.75rem;
    background: none; border: none; color: var(--color-muted);
    font-size: 1.6rem; line-height: 1; cursor: pointer;
    min-width: 44px; min-height: 44px;
  }
  .seal-close:hover, .seal-close:focus-visible { color: var(--color-gold); }

  @media (max-width: 900px) {
    .stats-grid { grid-template-columns: repeat(2, 1fr); }
    .achievements-layout { grid-template-columns: 1fr; }
  }
  @media (max-width: 480px) {
    .stats-grid { grid-template-columns: 1fr; }
    .am-case-head { grid-template-columns: auto 1fr; }
    .am-case-toggle { grid-column: 1 / -1; justify-content: center; }
  }
  @media (prefers-reduced-motion: reduce) {
    .am-toggle-icon { transition: none; }
  }
</style>

<script>
  // Expandable case studies
  document.querySelectorAll<HTMLElement>('.am-case').forEach((card) => {
    const btn = card.querySelector<HTMLButtonElement>('.am-case-toggle');
    const panel = card.querySelector<HTMLElement>('.am-case-panel');
    const label = card.querySelector<HTMLElement>('.am-toggle-label');
    if (!btn || !panel) return;
    btn.addEventListener('click', () => {
      const open = card.classList.toggle('open');
      btn.setAttribute('aria-expanded', String(open));
      panel.hidden = !open;
      if (label) label.textContent = open ? 'Case study' : 'View case study';
    });
  });

  // Golden State Seal modal
  const backdrop = document.getElementById('seal-backdrop');
  const openBtn = document.getElementById('seal-open');
  const closeBtn = document.getElementById('seal-close');
  const open = () => { if (backdrop) { backdrop.hidden = false; openBtn?.setAttribute('aria-expanded', 'true'); closeBtn?.focus(); } };
  const close = () => { if (backdrop) { backdrop.hidden = true; openBtn?.setAttribute('aria-expanded', 'false'); openBtn?.focus(); } };
  openBtn?.addEventListener('click', open);
  closeBtn?.addEventListener('click', close);
  backdrop?.addEventListener('click', (e) => { if (e.target === backdrop) close(); });
  document.addEventListener('keydown', (e) => {
    if (!backdrop || backdrop.hidden) return;
    if (e.key === 'Escape') close();
    else if (e.key === 'Tab') { e.preventDefault(); closeBtn?.focus(); } // trap focus (single control)
  });
</script>
