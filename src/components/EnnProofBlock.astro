---
// Leadership proof band for the homepage. Text + deliverable tags, no image
// (real ENN artifacts get added on the Achievements/Portfolio pages later).
const deliverables = [
  'New logo set',
  'On-air graphics system',
  'Standardized production workflow',
  'Program website',
];
---
<section class="enn-proof" aria-labelledby="enn-proof-h">
  <div class="container enn-proof-inner">
    <span class="eyebrow">Leadership</span>
    <h2 id="enn-proof-h">Lead Studio Director, now President of ENN Studios.</h2>
    <p class="enn-proof-lead">
      I'm leading a six-figure relaunch of my school's broadcast program. The work I'm
      proudest of, and the systems I build this year are what the next class inherits.
    </p>
    <ul class="enn-deliverables" role="list">
      {deliverables.map((d) => <li>{d}</li>)}
    </ul>
    <a href="/achievements" class="btn btn-primary">See the full record</a>
  </div>
</section>

<style>
  .enn-proof {
    background: var(--color-bg);
    border-bottom: 1px solid var(--color-border);
    padding-block: clamp(3.5rem, 7vw, 6.5rem);
  }
  .enn-proof-inner {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    max-width: 760px;
  }
  .enn-proof h2 {
    font-family: var(--font-display);
    color: var(--color-text);
    font-size: clamp(1.7rem, 3.4vw, 2.6rem);
    line-height: 1.18;
    margin: 1rem 0 1.1rem;
  }
  .enn-proof-lead {
    color: var(--color-text-dim);
    line-height: 1.75;
    font-size: clamp(0.98rem, 1.4vw, 1.1rem);
    margin-bottom: 1.75rem;
    max-width: 60ch;
  }
  .enn-deliverables {
    list-style: none;
    margin: 0 0 2.25rem;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }
  .enn-deliverables li {
    font-size: 0.72rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    font-weight: 600;
    color: var(--color-text-dim);
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    padding: 0.5rem 0.85rem;
  }
</style>
