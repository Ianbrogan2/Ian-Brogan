---
import type { SiteData } from '../lib/content';
interface Props { site: SiteData; }
const { site } = Astro.props;
const { contact } = site;
---

<section id="contact" class="section" aria-labelledby="contact-heading">
  <div class="container">
    <div class="contact-layout">
      <div class="contact-text">
        <div class="contact-channels-label">Direct</div>
        <ul class="contact-channels" role="list">
          <li>
            <a href={`mailto:${contact.email}`} class="channel-link">
              <span class="channel-icon" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                  <polyline points="22,6 12,13 2,6"/>
                </svg>
              </span>
              <span>{contact.email}</span>
            </a>
          </li>
          <li>
            <a href={contact.instagram_main_url} target="_blank" rel="noopener noreferrer" class="channel-link">
              <span class="channel-icon" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
                  <path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/>
                  <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
                </svg>
              </span>
              <span>{contact.instagram_main_handle}</span>
            </a>
          </li>
          <li>
            <a href={contact.instagram_food_url} target="_blank" rel="noopener noreferrer" class="channel-link">
              <span class="channel-icon" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
                  <path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/>
                  <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
                </svg>
              </span>
              <span>{contact.instagram_food_handle} — food</span>
            </a>
          </li>
          {contact.linkedin_url && (
            <li>
              <a href={contact.linkedin_url} target="_blank" rel="noopener noreferrer" class="channel-link">
                <span class="channel-icon" aria-hidden="true">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6z"/>
                    <rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/>
                  </svg>
                </span>
                <span>LinkedIn</span>
              </a>
            </li>
          )}
        </ul>

        <a href="/resume" class="btn btn-outline resume-dl">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4M7 10l5 5 5-5M12 15V3"/>
          </svg>
          View résumé
        </a>
      </div>

      <div class="contact-form-wrap">
        <form
          method="POST"
          action="https://formspree.io/f/xwvjbgqe"
          class="contact-form"
          id="contact-form"
          novalidate
          aria-label="Contact form"
        >
          <div class="form-group">
            <label for="name">Name</label>
            <input type="text" id="name" name="name" required autocomplete="name" placeholder="Your name" />
          </div>
          <div class="form-group">
            <label for="email">Email</label>
            <input type="email" id="email" name="email" required autocomplete="email" placeholder="your@email.com" />
          </div>
          <div class="form-group">
            <label for="subject">Subject</label>
            <input type="text" id="subject" name="subject" placeholder="What's this about?" />
          </div>
          <div class="form-group">
            <label for="message">Message</label>
            <textarea id="message" name="message" rows="5" required placeholder="Your message"></textarea>
          </div>
          <button type="submit" class="btn btn-primary form-submit">
            Send message
          </button>
          <p class="form-success" id="form-success" role="status" aria-live="polite" hidden>
            Message sent — thanks for reaching out.
          </p>
          <p class="form-error" id="form-error" role="alert" aria-live="polite" hidden>
            Something went wrong. Email directly at ianbrogan2@hotmail.com
          </p>
        </form>
      </div>
    </div>
  </div>
</section>

<style>
  #contact { background: var(--color-surface); }

  .contact-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(3rem, 6vw, 7rem);
    align-items: start;
  }

  .contact-channels-label {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-muted);
    margin-bottom: 1.25rem;
  }

  .contact-channels {
    list-style: none;
    padding: 0;
    margin: 0 0 2rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .channel-link {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    text-decoration: none;
    font-size: 0.9rem;
    color: var(--color-text-dim);
    padding: 0.6rem 0;
    border-bottom: 1px solid var(--color-border);
    transition: color 0.2s, border-color 0.2s;
  }
  .channel-link:hover {
    color: var(--color-text);
    border-color: var(--color-gold);
  }
  .channel-icon { color: var(--color-muted); flex-shrink: 0; transition: color 0.2s; }
  .channel-link:hover .channel-icon { color: var(--color-gold); }

  .resume-dl {
    margin-top: 0.5rem;
    gap: 0.6rem;
  }

  .contact-form-wrap {
    background: var(--color-elevated);
    padding: clamp(1.5rem, 3vw, 2.5rem);
    border: 1px solid var(--color-border);
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    margin-bottom: 1.25rem;
  }

  label {
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-muted);
    font-weight: 600;
  }

  input, textarea {
    font-family: var(--font-body);
    font-size: 0.9rem;
    color: var(--color-text);
    background: var(--color-surface);
    border: 1.5px solid var(--color-border);
    padding: 0.7rem 0.9rem;
    width: 100%;
    transition: border-color 0.2s;
    outline: none;
    -webkit-appearance: none;
  }
  input::placeholder, textarea::placeholder { color: var(--color-muted); opacity: 0.7; }
  input:focus, textarea:focus {
    border-color: var(--color-gold);
  }
  textarea { resize: vertical; min-height: 120px; }

  .form-submit { width: 100%; justify-content: center; }

  .form-success {
    margin-top: 1rem;
    font-size: 0.875rem;
    color: #22c55e;
    font-style: italic;
  }
  .form-error {
    margin-top: 1rem;
    font-size: 0.875rem;
    color: #ef4444;
    font-style: italic;
  }

  @media (max-width: 768px) {
    .contact-layout { grid-template-columns: 1fr; }
    .contact-form-wrap { order: -1; }
  }
</style>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const successMsg = document.getElementById('form-success');

  const errorMsg = document.getElementById('form-error');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    // Guard: if endpoint still has placeholder ID, show error immediately
    if (form.action.includes('YOUR_FORM_ID')) {
      if (errorMsg) errorMsg.hidden = false;
      return;
    }
    const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement | null;
    if (btn) { btn.disabled = true; btn.textContent = 'Sending…'; }
    const data = new FormData(form);
    try {
      const res = await fetch(form.action, {
        method: 'POST',
        body: data,
        headers: { Accept: 'application/json' },
      });
      if (res.ok) {
        form.reset();
        if (successMsg) { successMsg.hidden = false; }
        if (btn) btn.hidden = true;
      } else {
        if (errorMsg) errorMsg.hidden = false;
        if (btn) { btn.disabled = false; btn.textContent = 'Send message'; }
      }
    } catch {
      if (errorMsg) errorMsg.hidden = false;
      if (btn) { btn.disabled = false; btn.textContent = 'Send message'; }
    }
  });
</script>
