---
import '../styles/global.css';
import { ViewTransitions } from 'astro:transitions';
import { getSite } from '../lib/content';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  noIndex?: boolean;
  bodyClass?: string;
}

const site = getSite();
const {
  title,
  description = site.meta.description,
  ogImage = site.meta.og_image,
  noIndex = false,
  bodyClass = '',
} = Astro.props;

const pageTitle = title ? `${title} — ${site.meta.title}` : `${site.meta.title} — ${site.meta.tagline}`;
const canonicalURL = new URL(Astro.url.pathname, site.meta.url);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <!-- Canonical & indexing -->
    <link rel="canonical" href={canonicalURL} />
    {noIndex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Title & description -->
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="author" content={site.meta.author} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, site.meta.url)} />
    <meta property="og:site_name" content={site.meta.title} />

    <!-- Twitter card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, site.meta.url)} />

    <!-- JSON-LD Person schema -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      "name": site.meta.author,
      "url": site.meta.url,
      "description": site.meta.description,
      "knowsAbout": ["Finance", "Investing", "Data Analytics", "3D Design", "Film Production", "Culinary Arts"],
      "sameAs": [
        site.contact.instagram_main_url,
        site.contact.instagram_food_url,
        ...(site.contact.linkedin_url ? [site.contact.linkedin_url] : []),
        ...(site.contact.github_url ? [site.contact.github_url] : []),
      ],
    })} />

    <!-- Favicons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <ViewTransitions />
  </head>
  <body class={bodyClass}>
    <slot />
    <script>
      // Reveal-on-scroll observer
      const reveals = document.querySelectorAll('.reveal');
      if (reveals.length) {
        const io = new IntersectionObserver(
          (entries) => entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); io.unobserve(e.target); } }),
          { threshold: 0.12 }
        );
        reveals.forEach(el => io.observe(el));
      }
    </script>
  </body>
</html>
