---
import Base from './Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { getSite } from '../lib/content';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  noIndex?: boolean;
  noPadding?: boolean;
}

const site = getSite();
const { title, description, ogImage, noIndex = false, noPadding = false } = Astro.props;
---

<Base title={title} description={description} ogImage={ogImage} noIndex={noIndex}>
  <Nav site={site} />
  <main id="main" tabindex="-1" class={noPadding ? '' : ''}>
    <slot />
  </main>
  <Footer site={site} />
</Base>
