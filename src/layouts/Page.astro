---
import Base from './Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Cursor from '../components/Cursor.astro';
import ClickFx from '../components/ClickFx.astro';
import LiquidTitles from '../components/LiquidTitles.astro';
import { getSite } from '../lib/content';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  noIndex?: boolean;
  noPadding?: boolean;
}

const site = getSite();
const { title, description, ogImage, noIndex = false } = Astro.props;
---

<Base title={title} description={description} ogImage={ogImage} noIndex={noIndex}>
  <Cursor />
  <ClickFx />
  <LiquidTitles />
  <Nav site={site} />
  <main id="main" tabindex="-1">
    <slot />
  </main>
  <Footer site={site} />
</Base>
