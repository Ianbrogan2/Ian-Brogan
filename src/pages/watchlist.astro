---
import Page from '../layouts/Page.astro';
---

<Page
  title="Watchlist"
  description="Ian Brogan's live market watchlist — tickers I follow, sectors I study, and the data I watch every day."
>
  <div class="page-hero container">
    <span class="eyebrow">Watchlist</span>
    <span class="rule-gold"></span>
    <h1>What I'm watching.</h1>
    <p class="lead">The tickers, sectors, and instruments on my radar — live data via TradingView.</p>
  </div>

  <div class="watchlist-wrap container">

    <!-- Screener / market overview widget -->
    <div class="widget-block">
      <h2 class="widget-label">Market Overview</h2>
      <div class="tradingview-widget-container">
        <div class="tradingview-widget-container__widget"></div>
        <script type="text/javascript" src="https://s3.tradingview.com/external-embedding/embed-widget-market-overview.js" async>
        {
          "colorTheme": "dark",
          "dateRange": "12M",
          "showChart": true,
          "locale": "en",
          "largeChartUrl": "",
          "isTransparent": true,
          "showSymbolLogo": false,
          "showFloatingTooltip": false,
          "width": "100%",
          "height": "600",
          "tabs": [
            {
              "title": "Indices",
              "symbols": [
                { "s": "FOREXCOM:SPXUSD", "d": "S&P 500 Index" },
                { "s": "FOREXCOM:NSXUSD", "d": "US 100 Cash CFD" },
                { "s": "FOREXCOM:DJI", "d": "Dow Jones Index" },
                { "s": "INDEX:NKY", "d": "Nikkei 225" },
                { "s": "INDEX:DEU40", "d": "DAX Index" },
                { "s": "FOREXCOM:UKXGBP", "d": "UK 100 Index" }
              ],
              "originalTitle": "Indices"
            },
            {
              "title": "Equities",
              "symbols": [
                { "s": "NASDAQ:AAPL" },
                { "s": "NASDAQ:MSFT" },
                { "s": "NYSE:BRK.B" },
                { "s": "NYSE:JPM" },
                { "s": "NASDAQ:GOOGL" },
                { "s": "NYSE:GS" }
              ],
              "originalTitle": "Equities"
            },
            {
              "title": "Bonds",
              "symbols": [
                { "s": "CBOT:ZB1!", "d": "T-Bond" },
                { "s": "CBOT:UB1!", "d": "Ultra T-Bond" },
                { "s": "EUREX:FGBL1!", "d": "Euro Bund" },
                { "s": "EUREX:FBTP1!", "d": "Euro BTP" },
                { "s": "EUREX:FGBM1!", "d": "Euro BOBL" }
              ],
              "originalTitle": "Bonds"
            },
            {
              "title": "Forex",
              "symbols": [
                { "s": "FX:EURUSD", "d": "EUR to USD" },
                { "s": "FX:GBPUSD", "d": "GBP to USD" },
                { "s": "FX:USDJPY", "d": "USD to JPY" },
                { "s": "FX:USDCHF", "d": "USD to CHF" },
                { "s": "FX:AUDUSD", "d": "AUD to USD" },
                { "s": "FX:USDCAD", "d": "USD to CAD" }
              ],
              "originalTitle": "Forex"
            }
          ]
        }
        </script>
      </div>
    </div>

    <!-- Ticker tape of the stocks I follow -->
    <div class="widget-block">
      <h2 class="widget-label">Tickers I Follow</h2>
      <div class="tradingview-widget-container">
        <div class="tradingview-widget-container__widget"></div>
        <script type="text/javascript" src="https://s3.tradingview.com/external-embedding/embed-widget-ticker-tape.js" async>
        {
          "symbols": [
            { "proName": "FOREXCOM:SPXUSD", "title": "S&P 500" },
            { "proName": "FOREXCOM:NSXUSD", "title": "Nasdaq 100" },
            { "proName": "FX_IDC:EURUSD", "title": "EUR/USD" },
            { "proName": "BITSTAMP:BTCUSD", "title": "BTC/USD" },
            { "description": "Apple", "proName": "NASDAQ:AAPL" },
            { "description": "Microsoft", "proName": "NASDAQ:MSFT" },
            { "description": "JPMorgan", "proName": "NYSE:JPM" },
            { "description": "Berkshire B", "proName": "NYSE:BRK.B" },
            { "description": "Goldman", "proName": "NYSE:GS" },
            { "description": "10Y Treasury", "proName": "TVC:US10Y" },
            { "description": "Gold", "proName": "TVC:GOLD" },
            { "description": "WTI Crude", "proName": "TVC:USOIL" }
          ],
          "showSymbolLogo": false,
          "isTransparent": true,
          "displayMode": "adaptive",
          "colorTheme": "dark",
          "locale": "en"
        }
        </script>
      </div>
    </div>

    <!-- Crypto market mini chart -->
    <div class="widget-block">
      <h2 class="widget-label">Economic Calendar</h2>
      <div class="tradingview-widget-container">
        <div class="tradingview-widget-container__widget"></div>
        <script type="text/javascript" src="https://s3.tradingview.com/external-embedding/embed-widget-events.js" async>
        {
          "colorTheme": "dark",
          "isTransparent": true,
          "width": "100%",
          "height": "450",
          "locale": "en",
          "importanceFilter": "0,1",
          "countryFilter": "us"
        }
        </script>
      </div>
    </div>

    <div class="watchlist-note">
      <p>Data provided by <a href="https://www.tradingview.com" target="_blank" rel="noopener noreferrer">TradingView</a>. Tickers shown are instruments I track for research — not investment advice.</p>
    </div>

  </div>
</Page>

<style>
  .page-hero {
    padding-top: clamp(8rem, 12vw, 12rem);
    padding-bottom: clamp(2rem, 3vw, 3rem);
  }
  h1 { margin-bottom: 1rem; }

  .watchlist-wrap {
    padding-bottom: clamp(4rem, 8vw, 8rem);
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  .widget-block {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .widget-label {
    font-family: var(--font-body);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-gold);
    margin: 0;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--color-border);
  }

  .tradingview-widget-container {
    background: var(--color-elevated);
    border: 1px solid var(--color-border);
    overflow: hidden;
  }

  .watchlist-note {
    padding-top: 1rem;
    border-top: 1px solid var(--color-border);
  }
  .watchlist-note p {
    font-size: 0.75rem;
    color: var(--color-muted);
    margin: 0;
  }
  .watchlist-note a {
    color: var(--color-gold);
    text-decoration: none;
  }
  .watchlist-note a:hover { color: var(--color-text); }
</style>
