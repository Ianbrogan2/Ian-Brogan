---
import Page from '../layouts/Page.astro';
import Skills from '../components/Skills.astro';
import { getSkills } from '../lib/content';

const skills = getSkills();
---

<Page title="Skills" description="Ian Brogan's technical and creative skill set — finance, design, production, and more.">
  <div class="page-hero container">
    <span class="eyebrow">Skills</span>
    <span class="rule-gold"></span>
    <h1>What I Can Do.</h1>
    <p class="lead">Finance, design, fabrication, culinary. I pick things up and go deep. The breadth is intentional.</p>
  </div>
  <Skills data={skills} />
</Page>

<style>
  .page-hero {
    padding-top: clamp(8rem, 12vw, 12rem);
    padding-bottom: clamp(2rem, 4vw, 4rem);
    border-bottom: 1px solid var(--color-border);
  }
  h1 { margin-bottom: 1rem; }
</style>
