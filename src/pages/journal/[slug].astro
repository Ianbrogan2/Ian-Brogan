---
import { getCollection, render } from 'astro:content';
import Page from '../../layouts/Page.astro';

export async function getStaticPaths() {
  const posts = await getCollection('journal', ({ data }) => !data.draft);
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

function formatDate(d: Date) {
  return d.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
}
---

<Page
  title={post.data.title}
  description={post.data.description}
  ogImage={post.data.image}
>
  <article class="journal-post">
    <header class="post-header container">
      <a href="/journal" class="back-link">← Journal</a>
      <div class="post-meta">
        <time datetime={post.data.date.toISOString()}>{formatDate(post.data.date)}</time>
        {post.data.tags?.map(tag => <span class="post-tag">{tag}</span>)}
      </div>
      <h1 data-liquid>{post.data.title}</h1>
      <p class="post-deck">{post.data.description}</p>
    </header>

    <div class="post-body container">
      <Content />
    </div>

    <footer class="post-footer container">
      <a href="/journal" class="btn btn-outline">← Back to journal</a>
    </footer>
  </article>
</Page>

<style>
  .post-header {
    padding-top: clamp(7rem, 10vw, 10rem);
    padding-bottom: clamp(2.5rem, 4vw, 4rem);
    max-width: 760px;
    border-bottom: 1px solid var(--color-bone-dk);
    margin-bottom: 3rem;
  }

  .back-link {
    display: inline-block;
    font-size: 0.8rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-mist);
    text-decoration: none;
    margin-bottom: 1.5rem;
    transition: color 0.2s;
  }
  .back-link:hover { color: var(--color-oxblood); }

  .post-meta {
    display: flex;
    gap: 0.75rem;
    align-items: center;
    flex-wrap: wrap;
    margin-bottom: 1.25rem;
  }
  time {
    font-size: 0.75rem;
    letter-spacing: 0.06em;
    color: var(--color-mist);
    text-transform: uppercase;
  }
  .post-tag {
    font-size: 0.68rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-oxblood);
    padding: 0.2em 0.5em;
    border: 1px solid rgba(107,31,42,0.3);
  }

  h1 {
    font-size: clamp(1.75rem, 4vw, 3rem);
    margin: 0 0 1rem;
    color: var(--color-oxblood-dk);
  }

  .post-deck {
    font-size: clamp(1rem, 1.5vw, 1.2rem);
    color: var(--color-text-dim);
    line-height: 1.6;
    max-width: 60ch;
    margin: 0;
    font-style: italic;
  }

  /* Post body prose */
  .post-body {
    max-width: 760px;
    padding-bottom: 4rem;
  }

  .post-body :global(h2) {
    font-size: clamp(1.2rem, 2.5vw, 1.6rem);
    margin: 2.5rem 0 1rem;
    color: var(--color-oxblood-dk);
  }
  .post-body :global(h3) {
    font-size: 1.1rem;
    margin: 2rem 0 0.75rem;
  }
  .post-body :global(p) {
    font-size: 1rem;
    line-height: 1.75;
    color: var(--color-text-dim);
    margin-bottom: 1.5em;
  }
  .post-body :global(hr) {
    border: none;
    border-top: 1px solid var(--color-bone-dk);
    margin: 3rem 0;
  }
  .post-body :global(em) { color: var(--color-ink); font-style: italic; }
  .post-body :global(strong) { font-weight: 600; color: var(--color-oxblood-dk); }
  .post-body :global(blockquote) {
    margin: 2rem 0;
    padding-left: 1.5rem;
    border-left: 3px solid var(--color-gold);
    font-style: italic;
    color: var(--color-text-dim);
  }

  .post-footer {
    padding-bottom: clamp(4rem, 8vw, 8rem);
  }
</style>
