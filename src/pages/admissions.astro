---
// Hidden from public nav · for college admissions readers
import Page from '../layouts/Page.astro';
import { getSite, getAbout, getResume, getVision } from '../lib/content';

const site = getSite();
const about = getAbout();
const r = getResume();
const vision = getVision();
---

<Page
  title="Admissions Profile"
  description="Ian Brogan, prospective Business Economics student. Admissions reader view."
  noIndex={true}
>
  <div class="container admissions-page">
    <header class="adm-header">
      <p class="eyebrow">For admissions readers</p>
      <h1>Ian Brogan, Prospective Student</h1>
      <p class="lead">{about.subhead}</p>

      <div class="adm-contact">
        <a href={`mailto:${site.contact.email}`}>{site.contact.email}</a>
        <span>·</span>
        <a href={site.contact.instagram_main_url} target="_blank" rel="noopener noreferrer">
          {site.contact.instagram_main_handle}
        </a>
        <span>·</span>
        <a href="/resume">View résumé</a>
      </div>
    </header>

    <!-- Story -->
    <section class="adm-section">
      <h2>My story</h2>
      <div class="adm-story">
        {about.body.map(p => <p>{p}</p>)}
      </div>
    </section>

    <!-- Why these schools -->
    <section class="adm-section">
      <h2>{vision.schools.headline}</h2>
      <ul class="adm-schools">
        {vision.schools.items.map(s => (
          <li>
            <strong>{s.name}</strong>
            <span>{s.program}</span>
            <span class="note">{s.note}</span>
          </li>
        ))}
      </ul>
    </section>

    <!-- Experience highlights -->
    <section class="adm-section">
      <h2>Experience</h2>
      {r.experience.map(exp => (
        <div class="adm-entry">
          <div class="entry-header">
            <strong>{exp.title}</strong>
            <em>{exp.org} · {exp.years}</em>
          </div>
          <ul>
            {exp.bullets.map(b => <li>{b}</li>)}
          </ul>
        </div>
      ))}
    </section>

    <!-- Skills -->
    <section class="adm-section">
      <h2>Skills</h2>
      {r.skills_summary.map(s => (
        <p><strong>{s.category}:</strong> {s.items}</p>
      ))}
    </section>

    <!-- Career vision -->
    <section class="adm-section">
      <h2>Career vision</h2>
      <ol class="adm-arc">
        {vision.career_arc.stages.map(s => (
          <li>
            <span class="phase">{s.phase}</span>
            <strong>{s.label}</strong>
            <span>{s.detail}</span>
          </li>
        ))}
      </ol>
    </section>

    <footer class="adm-footer">
      <p>Full portfolio and writing at <a href={site.meta.url}>{site.meta.url}</a></p>
    </footer>
  </div>
</Page>

<style>
  .admissions-page {
    padding-top: clamp(7rem, 10vw, 10rem);
    padding-bottom: clamp(4rem, 8vw, 8rem);
    max-width: 820px;
  }

  .adm-header {
    margin-bottom: 3rem;
    padding-bottom: 2rem;
    border-bottom: 2px solid var(--color-gold);
  }
  h1 { margin-bottom: 0.75rem; }
  .lead { margin-bottom: 1.25rem; }
  .adm-contact {
    display: flex;
    gap: 0.75rem;
    font-size: 0.875rem;
    color: var(--color-muted);
    flex-wrap: wrap;
  }
  .adm-contact a { color: var(--color-gold); text-decoration: none; }
  .adm-contact a:hover { color: var(--color-text); }

  .adm-section {
    margin-bottom: 2.5rem;
    padding-bottom: 2.5rem;
    border-bottom: 1px solid var(--color-elevated);
  }
  .adm-section:last-of-type { border: none; }

  h2 {
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-gold);
    font-family: var(--font-body);
    font-weight: 600;
    margin: 0 0 1.25rem;
  }

  .adm-story p { color: var(--color-text-dim); }

  .adm-schools {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .adm-schools li {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    padding: 1rem;
    background: var(--color-elevated);
  }
  .adm-schools strong { font-size: 1rem; color: var(--color-text); }
  .adm-schools span { font-size: 0.875rem; color: var(--color-text-dim); }
  .adm-schools .note { font-size: 0.8rem; color: var(--color-muted); font-style: italic; }

  .adm-entry { margin-bottom: 1.25rem; }
  .entry-header {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    align-items: baseline;
    margin-bottom: 0.5rem;
  }
  .adm-entry strong { font-size: 0.95rem; }
  .adm-entry em { font-size: 0.8rem; color: var(--color-muted); }
  .adm-entry ul { margin: 0; padding-left: 1.25rem; }
  .adm-entry li { font-size: 0.875rem; color: var(--color-text-dim); margin-bottom: 0.25rem; }

  .adm-arc {
    padding-left: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .adm-arc li {
    display: flex;
    flex-direction: column;
    font-size: 0.875rem;
    gap: 0.15rem;
  }
  .adm-arc .phase {
    font-size: 0.68rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-gold);
  }
  .adm-arc strong { color: var(--color-text); }
  .adm-arc span:last-child { color: var(--color-text-dim); }

  .adm-footer {
    margin-top: 2rem;
    font-size: 0.8rem;
    color: var(--color-muted);
  }
  .adm-footer p { max-width: none; }
  .adm-footer a { color: var(--color-gold); }
</style>
