---
import Page from '../layouts/Page.astro';
import Hero from '../components/Hero.astro';
import { getSite } from '../lib/content';

const site = getSite();
---

<Page>
  <Hero site={site} />

  <!-- The Goal — aspirations + proof, the engine of the homepage -->
  <section class="goal" aria-label="The goal">
    <div class="container goal-inner">
      <span class="eyebrow">The Goal</span>
      <span class="rule-gold"></span>
      <h2 class="goal-headline">I'm not looking for a job. I'm building toward something specific.</h2>
      <p class="goal-arc">
        Business Economics, then a way into BlackRock through a family connection.
        From there, data analyst to senior analyst, learning how institutional
        capital actually moves. The goal is fund manager: real capital, real
        conviction. The endgame is a vineyard, the same patience that holds a
        position through volatility is the patience that waits for a vintage.
      </p>
      <p class="goal-proof">
        <span class="proof-label">Proof it's not just talk:</span>
        when U.S.-Iran tensions escalated, I worked through which sectors stood to
        benefit, landed on cybersecurity, and held PANW and CRWD through the
        volatility. The thesis paid off. Seven years of studying markets, tested
        in real time.
      </p>
      <div class="goal-links">
        <a href="/about" class="btn btn-primary">Read the full story</a>
        <span class="goal-hint">See everything I've done to get here</span>
      </div>
    </div>
  </section>
</Page>

<style>
  .goal {
    background: var(--color-surface);
    padding-block: clamp(4rem, 8vw, 8rem);
    border-top: 1px solid var(--color-border);
  }

  .goal-inner {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    max-width: 760px;
  }

  .goal-headline {
    font-family: var(--font-display);
    font-size: clamp(1.6rem, 3.5vw, 2.6rem);
    font-variation-settings: 'opsz' 48;
    font-weight: 600;
    line-height: 1.3;
    color: var(--color-text);
    margin: 1.5rem 0 1.5rem;
  }

  .goal-arc, .goal-proof {
    font-size: clamp(0.95rem, 1.4vw, 1.05rem);
    line-height: 1.75;
    color: var(--color-text-dim);
    max-width: none;
  }

  .goal-proof {
    margin-top: 1.25rem;
    padding-left: 1.25rem;
    border-left: 3px solid var(--color-gold);
  }

  .proof-label {
    color: var(--color-gold);
    font-weight: 700;
    letter-spacing: 0.02em;
  }

  .goal-links {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    flex-wrap: wrap;
    margin-top: 2.5rem;
  }

  .goal-hint {
    font-size: 0.8rem;
    color: var(--color-muted);
    font-style: italic;
  }

  @media (max-width: 600px) {
    .goal-links {
      flex-direction: column;
      align-items: stretch;
      gap: 0.75rem;
    }
    .goal-links .btn { text-align: center; }
    .goal-hint { text-align: center; }
  }
</style>
