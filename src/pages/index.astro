---
import Page from '../layouts/Page.astro';
import Hero from '../components/Hero.astro';
import About from '../components/About.astro';
import Journey from '../components/Journey.astro';
import Portfolio from '../components/Portfolio.astro';
import Investing from '../components/Investing.astro';
import Skills from '../components/Skills.astro';
import Vision from '../components/Vision.astro';
import JournalPreview from '../components/JournalPreview.astro';
import Contact from '../components/Contact.astro';
import Ticker from '../components/Ticker.astro';

import { getSite, getAbout, getJourney, getPortfolio, getSkills, getInvesting, getVision } from '../lib/content';
import { getCollection } from 'astro:content';

const site = getSite();
const about = getAbout();
const journey = getJourney();
const portfolio = getPortfolio();
const skills = getSkills();
const investing = getInvesting();
const vision = getVision();

const allPosts = await getCollection('journal', ({ data }) => !data.draft);
const recentPosts = allPosts
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---

<Page>
  <Hero site={site} />
  <Ticker />
  <About data={about} />
  <Journey data={journey} />
  <Portfolio data={portfolio} preview={true} />
  <Investing data={investing} />
  <Skills data={skills} />
  <Vision data={vision} />
  <JournalPreview posts={recentPosts} />
  <Contact site={site} />
</Page>
