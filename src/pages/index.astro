---
import Page from '../layouts/Page.astro';
import Hero from '../components/Hero.astro';
import { getSite } from '../lib/content';

const site = getSite();
---

<Page>
  <Hero site={site} />

  <!-- Journey teaser — just enough to intrigue, links to full page -->
  <section class="journey-teaser" aria-label="Journey highlights">
    <div class="container jt-inner">
      <div class="jt-header">
        <span class="eyebrow">The Journey</span>
        <span class="rule-gold"></span>
        <h2>From age ten to here.</h2>
        <p class="lead">Seven years of real investing, a Lead Studio Director role, and a path that's been deliberate from the start. The full timeline is on the Journey page.</p>
      </div>

      <div class="jt-milestones">
        <div class="jt-item">
          <span class="jt-age">Age 10</span>
          <span class="jt-label">First investment account</span>
        </div>
        <div class="jt-item">
          <span class="jt-age">Age 15</span>
          <span class="jt-label">Design, 3D printing & making</span>
        </div>
        <div class="jt-item">
          <span class="jt-age">Age 16</span>
          <span class="jt-label">Lead Studio Director</span>
        </div>
        <div class="jt-item jt-item--current">
          <span class="jt-age">Now</span>
          <span class="jt-label">Present — Summer 2026</span>
        </div>
      </div>

      <a href="/journey" class="btn btn-outline jt-cta">See the full journey →</a>
    </div>
  </section>
</Page>

<style>
  .journey-teaser {
    background: var(--color-surface);
    padding-block: clamp(4rem, 7vw, 7rem);
    border-top: 1px solid var(--color-border);
  }

  .jt-inner {
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  .jt-header {
    max-width: 600px;
  }
  .jt-header h2 {
    font-size: clamp(1.75rem, 3.5vw, 2.75rem);
    margin: 0.75rem 0 1rem;
  }
  .jt-header .lead { color: var(--color-text-dim); }

  .jt-milestones {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    border: 1px solid var(--color-border);
  }

  .jt-item {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1.5rem;
    border-right: 1px solid var(--color-border);
    position: relative;
  }
  .jt-item:last-child { border-right: none; }
  .jt-item::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: var(--color-border);
  }
  .jt-item--current::before {
    background: var(--color-gold);
  }

  .jt-age {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-gold);
  }
  .jt-label {
    font-family: var(--font-display);
    font-size: 1rem;
    font-variation-settings: 'opsz' 24;
    color: var(--color-text);
    line-height: 1.3;
  }
  .jt-item--current .jt-label { color: var(--color-text); }

  .jt-cta {
    align-self: flex-start;
  }

  @media (max-width: 768px) {
    .jt-milestones {
      grid-template-columns: 1fr 1fr;
    }
    .jt-item:nth-child(2) { border-right: none; }
    .jt-item:nth-child(3) { border-top: 1px solid var(--color-border); }
    .jt-item:nth-child(4) { border-right: none; border-top: 1px solid var(--color-border); }
  }

  @media (max-width: 480px) {
    .jt-milestones { grid-template-columns: 1fr; }
    .jt-item { border-right: none; border-top: 1px solid var(--color-border); }
    .jt-item:first-child { border-top: none; }
  }
</style>
