---
import Page from '../layouts/Page.astro';
import Hero from '../components/Hero.astro';
import CredentialsStrip from '../components/CredentialsStrip.astro';
import EnnProofBlock from '../components/EnnProofBlock.astro';
import { getSite } from '../lib/content';

const site = getSite();
---

<Page>
  <Hero site={site} />

  <!-- Credentials at a glance, immediately after the hero -->
  <CredentialsStrip />

  <!-- Leadership proof, before the finance career arc -->
  <EnnProofBlock />

  <!-- The Goal · aspirations + proof, the engine of the homepage -->
  <section class="goal" aria-label="The goal">
    <div class="container goal-inner">
      <span class="eyebrow">The Goal</span>
      <span class="rule-gold"></span>
      <h2 class="goal-headline" data-liquid>I'm not looking for a job. I'm building toward something specific.</h2>
      <p class="goal-arc">
        I'm majoring in Business Economics, then aiming for an internship at
        BlackRock, where my aunt used to work and still has connections that
        can open the door. From there, I want to work my way up the data analyst pathway,
        learning how capital moves and what's behind it with the resources of
        a larger company. The goal is to manage funds: real capital, and to
        keep learning everything I can about the markets. Eventually, I want
        to retire to a vineyard and live out my days with my family.
      </p>
      <p class="goal-proof">
        <span class="proof-label">An example of my trading philosophy:</span>
        look at macro clues and patterns, look into history for similar events.
        If you find the causation, you can repeat the pattern. I did this when
        U.S.-Iran tensions escalated: I worked my way through the sectors that
        stood to benefit and landed on cybersecurity, picking up PANW and CRWD.
        The thesis paid off. It's a small example among many, and proof of seven
        years spent studying the markets, the thing I'd rather do with my life
        than anything else.
      </p>
      <div class="goal-links">
        <a href="/about" class="btn btn-primary">Read the full story</a>
        <a href="/investing" class="btn btn-ghost" data-money>How I think about capital →</a>
        <span class="goal-hint">See everything I've done to get here</span>
      </div>
    </div>
  </section>
</Page>

<style>
  .goal {
    background: var(--color-surface);
    padding-block: clamp(4rem, 8vw, 8rem);
    border-top: 1px solid var(--color-border);
  }

  .goal-inner {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    max-width: 760px;
  }

  .goal-headline {
    font-family: var(--font-display);
    font-size: clamp(1.6rem, 3.5vw, 2.6rem);
    font-variation-settings: 'opsz' 48;
    font-weight: 600;
    line-height: 1.3;
    color: var(--color-text);
    margin: 1.5rem 0 1.5rem;
  }

  .goal-arc, .goal-proof {
    font-size: clamp(0.95rem, 1.4vw, 1.05rem);
    line-height: 1.75;
    color: var(--color-text-dim);
    max-width: none;
  }

  .goal-proof {
    margin-top: 1.25rem;
    padding-left: 1.25rem;
    border-left: 3px solid var(--color-gold);
  }

  .proof-label {
    color: var(--color-gold);
    font-weight: 700;
    letter-spacing: 0.02em;
  }

  .goal-links {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    flex-wrap: wrap;
    margin-top: 2.5rem;
  }

  .goal-hint {
    font-size: 0.8rem;
    color: var(--color-muted);
    font-style: italic;
  }

  @media (max-width: 600px) {
    .goal-links {
      flex-direction: column;
      align-items: stretch;
      gap: 0.75rem;
    }
    .goal-links .btn { text-align: center; }
    .goal-hint { text-align: center; }
  }
</style>
