---
import Page from '../layouts/Page.astro';
import Contact from '../components/Contact.astro';
import { getSite } from '../lib/content';

const site = getSite();
---

<Page title="Contact" description="Get in touch with Ian Brogan — for opportunities, connections, and conversations worth having.">
  <div class="page-hero container">
    <span class="eyebrow">Contact</span>
    <span class="rule-gold"></span>
    <h1>Let's Talk.</h1>
    <p class="lead">For opportunities, mentorship, or conversations worth having.</p>
  </div>
  <Contact site={site} />
</Page>

<style>
  .page-hero {
    padding-top: clamp(8rem, 12vw, 12rem);
    padding-bottom: clamp(2rem, 4vw, 4rem);
    border-bottom: 1px solid var(--color-border);
  }
  h1 { margin-bottom: 1rem; }
</style>
