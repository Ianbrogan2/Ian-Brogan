---
import Page from '../layouts/Page.astro';
import About from '../components/About.astro';
import { getAbout } from '../lib/content';

const about = getAbout();
---

<Page title="About" description="Who Ian Brogan is — background, skills, and the story behind the range.">
  <div class="page-hero container">
    <span class="eyebrow">About</span>
    <span class="rule-gold"></span>
    <h1>Who I Am.</h1>
    <p class="lead">Seven years of self-directed study. Real responsibility. A range that's a feature, not a bug.</p>
  </div>
  <About data={about} />
</Page>

<style>
  .page-hero {
    padding-top: clamp(8rem, 12vw, 12rem);
    padding-bottom: clamp(2rem, 4vw, 4rem);
    border-bottom: 1px solid var(--color-border);
  }
  h1 { margin-bottom: 1rem; }
</style>
