---
import Page from '../layouts/Page.astro';
import Investing from '../components/Investing.astro';
import { getInvesting } from '../lib/content';

const investing = getInvesting();
---

<Page title="Investing" description="Ian Brogan's investing philosophy, market approach, and financial thinking.">
  <div class="page-hero container">
    <span class="eyebrow">Investing</span>
    <span class="rule-gold"></span>
    <h1>How I Think About Capital.</h1>
    <p class="lead">Self-taught since ten. A framework built from first principles, not shortcuts.</p>
  </div>
  <Investing data={investing} />
</Page>

<style>
  .page-hero {
    padding-top: clamp(8rem, 12vw, 12rem);
    padding-bottom: clamp(2rem, 4vw, 4rem);
    border-bottom: 1px solid var(--color-border);
  }
  h1 { margin-bottom: 1rem; }
</style>
